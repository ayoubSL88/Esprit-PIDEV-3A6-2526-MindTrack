{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}Edit Humeur{% endblock %}

{% block content %}
    <div class="page-stack">
        {{ component('PageHeader', {
            eyebrow: 'Mood',
            title: 'Edit mood entry',
            copy: 'Adjust the details of this record.'
        }) }}

        {{ component('FlashStack') }}

        {% include 'admin/gestion_humeur/humeur/_form.html.twig' with {
            form: form,
            button_label: 'Update entry'
        } only %}

        <div class="button-row">
            <a class="btn-secondary" href="{{ path('front_gestion_humeur_index') }}">Back to list</a>
        </div>
    </div>
{% endblock %}
