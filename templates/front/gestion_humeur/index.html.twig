{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}Mon Humeur{% endblock %}

{% block content %}
    {% include 'humeur/_crud_styles.html.twig' %}

    <section class="crud-header">
        <div>
            <h1>My humeur journal</h1>
            <p>Track and review your mood entries in one place.</p>
        </div>
        <div class="header-actions">
            <a class="button-secondary" href="{{ path('front_gestion_humeur_journal_index') }}">Open journal</a>
            <a class="button-primary" href="{{ path('front_gestion_humeur_new') }}">Add entry</a>
        </div>
    </section>

    {% include 'humeur/_flash_messages.html.twig' %}

    <div class="card-shell">
        {% if humeurs is empty %}
            <p>No mood entries found yet.</p>
        {% else %}
            <div class="search-panel">
                <label for="humeur-search">Search humeur</label>
                <p>Type a mood type like `sad`, `anxious`, `happy`, or `neutural`.</p>
                <div class="search-toolbar">
                    <input
                        id="humeur-search"
                        class="search-input"
                        type="search"
                        placeholder="Search by humeur type..."
                        data-search-target="front-humeur-table"
                        data-empty-target="front-humeur-empty"
                    >
                    <div class="sort-group">
                        <label for="front-humeur-sort">Sort by date</label>
                        <select id="front-humeur-sort" class="sort-select">
                            <option value="latest">Latest</option>
                            <option value="oldest">Oldest</option>
                        </select>
                    </div>
                </div>
            </div>
            <table class="crud-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type humeur</th>
                        <th>Intensite</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="front-humeur-table">
                    {% for humeur in humeurs %}
                        <tr data-search-value="{{ humeur.typeHumeur|lower }}" data-date-value="{{ humeur.date|date('Y-m-d') }}">
                            <td>{{ humeur.date|date('Y-m-d') }}</td>
                            <td>{{ humeur.typeHumeur }}</td>
                            <td>{{ humeur.intensite }}/10</td>
                            <td class="actions-cell">
                                <a href="{{ path('front_gestion_humeur_show', {idH: humeur.idH}) }}">View</a>
                                <a href="{{ path('front_gestion_humeur_edit', {idH: humeur.idH}) }}">Edit</a>
                                {% include 'humeur/_delete_form.html.twig' with {
                                    delete_path: path('front_gestion_humeur_delete', {idH: humeur.idH}),
                                    csrf_token: csrf_token('delete_humeur_' ~ humeur.idH),
                                    button_label: 'Delete'
                                } only %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            <div id="front-humeur-empty" class="search-empty">No humeur matches your search.</div>
        {% endif %}
    </div>

    <script>
        (() => {
            const input = document.getElementById('humeur-search');
            const sort = document.getElementById('front-humeur-sort');
            if (!input || !sort) {
                return;
            }

            const tableBody = document.getElementById(input.dataset.searchTarget);
            const emptyState = document.getElementById(input.dataset.emptyTarget);
            const rows = Array.from(tableBody.querySelectorAll('tr'));

            const applyFilters = () => {
                const term = input.value.trim().toLowerCase();
                const direction = sort.value;
                const sortedRows = [...rows].sort((a, b) => {
                    const left = new Date(a.dataset.dateValue);
                    const right = new Date(b.dataset.dateValue);
                    return direction === 'oldest' ? left - right : right - left;
                });

                sortedRows.forEach((row) => tableBody.appendChild(row));

                let visibleCount = 0;

                sortedRows.forEach((row) => {
                    const searchable = row.dataset.searchValue || '';
                    const matches = term === '' || searchable.includes(term);
                    row.style.display = matches ? '' : 'none';
                    if (matches) {
                        visibleCount += 1;
                    }
                });

                emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
            };

            input.addEventListener('input', applyFilters);
            sort.addEventListener('change', applyFilters);
            applyFilters();
        })();
    </script>
{% endblock %}
