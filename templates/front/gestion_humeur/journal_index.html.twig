{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}Journal Emotionnel{% endblock %}

{% block content %}
    {% include 'humeur/_crud_styles.html.twig' %}

    <section class="crud-header">
        <div>
            <h1>My emotional journal</h1>
            <p>Write, review, and manage your personal journal entries.</p>
        </div>
        <a class="button-primary" href="{{ path('front_gestion_humeur_journal_new') }}">Add journal</a>
    </section>

    {% include 'humeur/_flash_messages.html.twig' %}

    <div class="card-shell">
        {% if journals is empty %}
            <p>No journal entries found yet.</p>
        {% else %}
            <div class="search-panel">
                <label for="journal-search">Search journal</label>
                <p>Type part of your note to filter your journal entries instantly.</p>
                <div class="search-toolbar">
                    <input
                        id="journal-search"
                        class="search-input"
                        type="search"
                        placeholder="Search by note..."
                        data-search-target="front-journal-table"
                        data-empty-target="front-journal-empty"
                    >
                    <div class="sort-group">
                        <label for="front-journal-sort">Sort by date</label>
                        <select id="front-journal-sort" class="sort-select">
                            <option value="latest">Latest</option>
                            <option value="oldest">Oldest</option>
                        </select>
                    </div>
                </div>
            </div>
            <table class="crud-table">
                <thead>
                    <tr>
                        <th>Note</th>
                        <th>Date creation</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="front-journal-table">
                    {% for journal in journals %}
                        <tr data-search-value="{{ journal.notePersonnelle|lower }}" data-date-value="{{ journal.dateCreation|date('c') }}">
                            <td>{{ journal.notePersonnelle|length > 80 ? journal.notePersonnelle|slice(0, 80) ~ '...' : journal.notePersonnelle }}</td>
                            <td>{{ journal.dateCreation|date('Y-m-d H:i') }}</td>
                            <td class="actions-cell">
                                <a href="{{ path('front_gestion_humeur_journal_show', {idJ: journal.idJ}) }}">View</a>
                                <a href="{{ path('front_gestion_humeur_journal_edit', {idJ: journal.idJ}) }}">Edit</a>
                                {% include 'journalemotionnel/_delete_form.html.twig' with {
                                    delete_path: path('front_gestion_humeur_journal_delete', {idJ: journal.idJ}),
                                    csrf_token: csrf_token('delete_journal_' ~ journal.idJ),
                                    button_label: 'Delete'
                                } only %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            <div id="front-journal-empty" class="search-empty">No journal entry matches your search.</div>
        {% endif %}
    </div>

    <script>
        (() => {
            const input = document.getElementById('journal-search');
            const sort = document.getElementById('front-journal-sort');
            if (!input || !sort) {
                return;
            }

            const tableBody = document.getElementById(input.dataset.searchTarget);
            const emptyState = document.getElementById(input.dataset.emptyTarget);
            const rows = Array.from(tableBody.querySelectorAll('tr'));

            const applyFilters = () => {
                const term = input.value.trim().toLowerCase();
                const direction = sort.value;
                const sortedRows = [...rows].sort((a, b) => {
                    const left = new Date(a.dataset.dateValue);
                    const right = new Date(b.dataset.dateValue);
                    return direction === 'oldest' ? left - right : right - left;
                });

                sortedRows.forEach((row) => tableBody.appendChild(row));

                let visibleCount = 0;

                sortedRows.forEach((row) => {
                    const searchable = row.dataset.searchValue || '';
                    const matches = term === '' || searchable.includes(term);
                    row.style.display = matches ? '' : 'none';
                    if (matches) {
                        visibleCount += 1;
                    }
                });

                emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
            };

            input.addEventListener('input', applyFilters);
            sort.addEventListener('change', applyFilters);
            applyFilters();
        })();
    </script>
{% endblock %}
