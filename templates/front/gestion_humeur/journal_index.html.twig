{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}Journal Emotionnel{% endblock %}

{% block content %}
    <div class="page-stack">
        {{ component('PageHeader', {
            eyebrow: 'Mood',
            title: 'My emotional journal',
            copy: 'Write, review, and manage your personal journal entries.'
        }) }}

        <div class="button-row">
            <a class="btn-primary" href="{{ path('front_gestion_humeur_journal_new') }}">Add journal</a>
        </div>

        {{ component('FlashStack') }}

        {% if journals is empty %}
            <p class="text-sm text-muted">No journal entries found yet.</p>
        {% else %}
            <div class="panel-section space-y-4">
                <div class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_220px] lg:items-end">
                    <div class="field">
                        <label class="field-label" for="journal-search">Search</label>
                        <input
                            id="journal-search"
                            class="field-input"
                            type="search"
                            placeholder="Search by note..."
                            data-search-target="front-journal-table"
                            data-empty-target="front-journal-empty"
                        >
                        <p class="text-xs text-muted">Type part of your note to filter instantly.</p>
                    </div>
                    <div class="field">
                        <label class="field-label" for="front-journal-sort">Sort by date</label>
                        <select id="front-journal-sort" class="field-select">
                            <option value="latest">Latest</option>
                            <option value="oldest">Oldest</option>
                        </select>
                    </div>
                </div>

                <div class="grid gap-4 lg:grid-cols-[220px_minmax(0,1fr)] lg:items-end">
                    <div class="field">
                        <label class="field-label" for="front-journal-filter-type">Filter by</label>
                        <select id="front-journal-filter-type" class="field-select">
                            <option value="date">Date</option>
                        </select>
                    </div>
                    <div class="field">
                        <label class="field-label" for="front-journal-filter-value">Filter value</label>
                        <input id="front-journal-filter-value" class="field-input" type="date">
                    </div>
                </div>
            </div>

            <div class="table-shell">
                <div class="table-wrap">
                    <table class="table">
                        <thead class="table-head">
                            <tr>
                                <th class="table-th">Note</th>
                                <th class="table-th">Date creation</th>
                                <th class="table-th">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="front-journal-table">
                            {% for journal in journals %}
                                <tr data-search-value="{{ journal.notePersonnelle|lower }}" data-date-value="{{ journal.dateCreation|date('c') }}">
                                    <td class="table-td">{{ journal.notePersonnelle|length > 80 ? journal.notePersonnelle|slice(0, 80) ~ '...' : journal.notePersonnelle }}</td>
                                    <td class="table-td">{{ journal.dateCreation|date('Y-m-d H:i') }}</td>
                                    <td class="table-td">
                                        <div class="button-row">
                                            <a class="btn-secondary px-4 py-2" href="{{ path('front_gestion_humeur_journal_show', {idJ: journal.idJ}) }}">View</a>
                                            <a class="btn-secondary px-4 py-2" href="{{ path('front_gestion_humeur_journal_edit', {idJ: journal.idJ}) }}">Edit</a>
                                            {% include 'admin/gestion_humeur/journalemotionnel/_delete_form.html.twig' with {
                                                delete_path: path('front_gestion_humeur_journal_delete', {idJ: journal.idJ}),
                                                csrf_token: csrf_token('delete_journal_' ~ journal.idJ),
                                                button_label: 'Delete'
                                            } only %}
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <p id="front-journal-empty" class="mt-4 text-sm text-muted hidden">No journal entry matches your search.</p>
        {% endif %}
    </div>

    <script>
        (() => {
            const input = document.getElementById('journal-search');
            const sort = document.getElementById('front-journal-sort');
            const filterValue = document.getElementById('front-journal-filter-value');
            if (!input || !sort || !filterValue) {
                return;
            }

            const tableBody = document.getElementById(input.dataset.searchTarget);
            const emptyState = document.getElementById(input.dataset.emptyTarget);
            const rows = Array.from(tableBody.querySelectorAll('tr'));

            const applyFilters = () => {
                const term = input.value.trim().toLowerCase();
                const direction = sort.value;
                const filterTerm = filterValue.value.trim().toLowerCase();
                const sortedRows = [...rows].sort((a, b) => {
                    const left = new Date(a.dataset.dateValue);
                    const right = new Date(b.dataset.dateValue);
                    return direction === 'oldest' ? left - right : right - left;
                });

                sortedRows.forEach((row) => tableBody.appendChild(row));

                let visibleCount = 0;

                sortedRows.forEach((row) => {
                    const searchable = row.dataset.searchValue || '';
                    const matchesSearch = term === '' || searchable.includes(term);
                    const matchesFilter = filterTerm === '' || (row.dataset.dateValue || '').includes(filterTerm);
                    const visible = matchesSearch && matchesFilter;
                    row.style.display = visible ? '' : 'none';
                    if (visible) {
                        visibleCount += 1;
                    }
                });

                emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
            };

            input.addEventListener('input', applyFilters);
            sort.addEventListener('change', applyFilters);
            filterValue.addEventListener('input', applyFilters);
            applyFilters();
        })();
    </script>
{% endblock %}
