{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}Journal Details{% endblock %}

{% block content %}
    <div class="page-stack">
        {{ component('PageHeader', {
            eyebrow: 'Mood',
            title: 'Journal entry',
            copy: 'Review your journal entry in detail.'
        }) }}

        {{ component('FlashStack') }}

        <div class="button-row">
            <a class="btn-secondary" href="{{ path('front_gestion_humeur_journal_index') }}">Back to list</a>
            {% if canEdit %}
                <a class="btn-primary" href="{{ path('front_gestion_humeur_journal_edit', {idJ: journal.idJ}) }}">Edit</a>
            {% else %}
                <span class="px-3 py-1 text-xs font-semibold text-muted">Editing is available only for 1 day after creation.</span>
            {% endif %}
        </div>

        <div class="panel-section grid gap-4 sm:grid-cols-2">
            <div>
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">Date creation</p>
                <p class="mt-2 text-sm font-semibold text-ink">{{ journal.dateCreation|date('Y-m-d H:i') }}</p>
            </div>
            <div class="sm:col-span-2">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">Note personnelle</p>
                <div class="mt-2 space-y-3 text-sm leading-7 text-ink">{{ journal.notePersonnelle|raw }}</div>
            </div>
        </div>

        {% if journal.screenshotPath or journal.audioPath %}
            <div class="panel-section grid gap-4 lg:grid-cols-2">
                {% if journal.screenshotPath %}
                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">Screenshot</p>
                        <img
                            src="{{ asset(journal.screenshotPath) }}"
                            alt="Journal screenshot"
                            class="mt-3 max-h-80 w-full rounded-2xl object-cover"
                        >
                    </div>
                {% endif %}

                {% if journal.audioPath %}
                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">Audio note</p>
                        <audio class="mt-3 w-full" controls preload="metadata">
                            <source src="{{ asset(journal.audioPath) }}">
                            Your browser does not support audio playback.
                        </audio>
                        <a class="btn-secondary mt-3 inline-flex" href="{{ asset(journal.audioPath) }}" download>Download audio</a>
                    </div>
                {% endif %}
            </div>
        {% endif %}

        <div class="button-row">
            {% include 'admin/gestion_humeur/journalemotionnel/_delete_form.html.twig' with {
                delete_path: path('front_gestion_humeur_journal_delete', {idJ: journal.idJ}),
                csrf_token: csrf_token('delete_journal_' ~ journal.idJ),
                button_label: 'Delete journal'
            } only %}
        </div>
    </div>
{% endblock %}
