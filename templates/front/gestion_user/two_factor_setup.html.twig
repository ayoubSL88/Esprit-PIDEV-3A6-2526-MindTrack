{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}Two-Factor Authentication{% endblock %}

{% block content %}
    <div class="page-stack">
        <header class="page-header">
            <h1 class="page-title">Two-Factor Authentication</h1>
            <p class="page-copy">Scan the QR code with Google Authenticator, Microsoft Authenticator, Authy, or another TOTP app, then verify one code to activate 2FA.</p>
        </header>

        <div class="flash-stack">
            {% for message in app.flashes('success') %}
                <div class="flash flash-success">{{ message }}</div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="flash flash-error">{{ message }}</div>
            {% endfor %}
        </div>

        <section class="grid gap-6 lg:grid-cols-[320px_minmax(0,1fr)]">
            <article class="panel-section">
                <p class="feature-label">Scan</p>
                <img src="{{ qr_code_url }}" alt="Two-factor authentication QR code" class="mt-4 w-full rounded-3xl border border-border bg-white p-4 shadow-soft">
                <p class="panel-copy mt-4">If QR scanning is unavailable, copy the manual secret below into your authenticator app.</p>
            </article>

            <article class="panel-section form-stack">
                <div>
                    <p class="feature-label">Manual Secret</p>
                    <div class="mt-4 rounded-3xl border border-border bg-white/90 p-4 text-sm font-semibold tracking-[0.16em] text-ink">{{ secret }}</div>
                </div>

                <form method="post" action="{{ path('front_gestion_user_totp_enable') }}" class="form-stack" novalidate>
                    <div class="field">
                        <label class="field-label" for="totp_code">Authenticator code</label>
                        <input class="field-input" id="totp_code" name="code" type="text" inputmode="numeric" autocomplete="one-time-code" maxlength="6" placeholder="000000" required autofocus>
                        <p class="text-sm text-muted">The code changes every {{ seconds_remaining }} seconds.</p>
                    </div>

                    <input type="hidden" name="secret" value="{{ secret }}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('front_profile_totp_enable_' ~ currentUser.idU) }}">

                    <div class="button-row">
                        <button type="submit" class="btn-primary">Verify and enable 2FA</button>
                        <a href="{{ path('front_gestion_user_index') }}" class="btn-secondary">Back to profile</a>
                    </div>
                </form>
            </article>
        </section>
    </div>
{% endblock %}
