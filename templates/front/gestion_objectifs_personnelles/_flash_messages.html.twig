{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="flash-message-front flash-{{ label == 'success' ? 'success' : 'error' }}">
            <div class="flash-icon">
                {% if label == 'success' %}
                    ✅
                {% else %}
                    ⚠️
                {% endif %}
            </div>
            <div class="flash-content">
                {{ message }}
            </div>
            <button class="flash-close" onclick="this.parentElement.remove()">✕</button>
        </div>
    {% endfor %}
{% endfor %}

<style>
    /* STYLE FRONT - FLASH MESSAGES MODERNES */
    .flash-message-front {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 20px;
        border-radius: 16px;
        background: white;
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.02);
        margin-bottom: 12px;
        animation: slideInRight 0.3s ease-out forwards;
        min-width: 280px;
        max-width: 400px;
        border-left: 4px solid;
    }
    
    .flash-message-front.flash-success {
        border-left-color: #10b981;
    }
    
    .flash-message-front.flash-success .flash-icon {
        color: #10b981;
    }
    
    .flash-message-front.flash-error {
        border-left-color: #ef4444;
    }
    
    .flash-message-front.flash-error .flash-icon {
        color: #ef4444;
    }
    
    .flash-icon {
        font-size: 1.3rem;
    }
    
    .flash-content {
        flex: 1;
        font-size: 0.85rem;
        font-weight: 500;
        color: #1e293b;
    }
    
    .flash-close {
        background: none;
        border: none;
        font-size: 1rem;
        cursor: pointer;
        color: #94a3b8;
        padding: 4px;
        transition: all 0.2s;
        border-radius: 8px;
    }
    
    .flash-close:hover {
        color: #475569;
        background: #f1f5f9;
    }
    
    @keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(100px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
    
    /* Auto-disparition après 5 secondes */
    .flash-message-front {
        animation: slideInRight 0.3s ease-out forwards, fadeOut 0.3s ease-out 4.7s forwards;
    }
    
    @keyframes fadeOut {
        to {
            opacity: 0;
            transform: translateX(100px);
            visibility: hidden;
        }
    }
    
    @media (max-width: 640px) {
        .flash-message-front {
            left: 20px;
            right: 20px;
            max-width: none;
        }
    }
</style>

<script>
    // Auto fermeture après 5 secondes
    setTimeout(() => {
        document.querySelectorAll('.flash-message-front').forEach(flash => {
            flash.remove();
        });
    }, 5000);
</script>