{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}{{ page_title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* STYLE FRONT - FORMULAIRE MODERNE EN CARTE */
        .form-card {
            background: white;
            border-radius: 24px;
            padding: 32px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.05);
            max-width: 800px;
            margin: 0 auto;
            transition: all 0.3s ease;
        }
        
        .form-grid {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }
        
        .form-grid > div {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        
        .form-grid label {
            font-weight: 600;
            font-size: 0.9rem;
            color: #1e293b;
        }
        
        .form-grid input, .form-grid select, .form-grid textarea {
            padding: 12px 16px;
            border: 1.5px solid #e2e8f0;
            border-radius: 14px;
            font-size: 0.95rem;
            transition: all 0.2s;
            background: #f8fafc;
        }
        
        .form-grid input:focus, .form-grid select:focus, .form-grid textarea:focus {
            border-color: #6366f1;
            outline: none;
            background: white;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
        }
        
        .checkbox-row {
            flex-direction: row !important;
            align-items: center;
            gap: 12px !important;
        }
        
        .checkbox-row input {
            width: 20px;
            height: 20px;
            cursor: pointer;
        }
        
        .field-error {
            color: #ef4444;
            font-size: 0.75rem;
            margin-top: 4px;
        }
        
        .actions {
            margin-top: 16px;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            border: none;
            padding: 12px 28px;
            border-radius: 40px;
            font-weight: 600;
            color: white;
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(99,102,241,0.3);
        }
        
        .btn-secondary {
            background: #f1f5f9;
            border: none;
            padding: 10px 24px;
            border-radius: 40px;
            color: #475569;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.2s;
        }
        
        .btn-secondary:hover {
            background: #e2e8f0;
        }
        
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            flex-wrap: wrap;
            gap: 16px;
        }
        
        .page-header h1 {
            font-size: 1.8rem;
            font-weight: 700;
            background: linear-gradient(135deg, #1e293b, #475569);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 0;
        }
        
        .grid {
            display: grid;
            gap: 20px;
        }
        
        @media (max-width: 640px) {
            .form-card {
                padding: 20px;
            }
            .page-header {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
{% endblock %}

