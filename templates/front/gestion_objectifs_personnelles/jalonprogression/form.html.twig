{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}{{ page_title }}{% endblock %}

{% block content %}
    {% include 'front/gestion_objectifs_personnelles/_flash_messages.html.twig' %}

    <section class="page-header">
        <div>
            <h1>{{ page_title }}</h1>
            <p>Renseigne le jalon, sa date cible et son état d’avancement.</p>
        </div>
        <a class="btn btn-secondary" href="{{ path('front_jalonprogression_index') }}">Retour à la liste</a>
    </section>

    <section class="form-card">
        {{ form_start(form, {attr: {class: 'form-grid'}}) }}
            {{ form_errors(form) }}
            <div>
                {{ form_label(form.idObj) }}
                {{ form_widget(form.idObj) }}
                <div class="field-error">{{ form_errors(form.idObj) }}</div>
            </div>
            <div>
                {{ form_label(form.titre) }}
                {{ form_widget(form.titre) }}
                <div class="field-error">{{ form_errors(form.titre) }}</div>
            </div>
            <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));">
                <div>
                    {{ form_label(form.dateCible) }}
                    {{ form_widget(form.dateCible) }}
                    <div class="field-error">{{ form_errors(form.dateCible) }}</div>
                </div>
                <div>
                    {{ form_label(form.dateAtteinte) }}
                    {{ form_widget(form.dateAtteinte) }}
                    <div class="field-error">{{ form_errors(form.dateAtteinte) }}</div>
                </div>
            </div>
            <div class="checkbox-row">
                {{ form_widget(form.atteint) }}
                {{ form_label(form.atteint) }}
            </div>
            <div class="field-error">{{ form_errors(form.atteint) }}</div>
            <div>
                {{ form_label(form.pourcentageProgression) }}
                {{ form_widget(form.pourcentageProgression) }}
                <div class="field-error">{{ form_errors(form.pourcentageProgression) }}</div>
            </div>
            <div class="actions">
                <button class="btn btn-primary" type="submit">{{ submit_label }}</button>
            </div>
        {{ form_end(form) }}
    </section>
{% endblock %}
