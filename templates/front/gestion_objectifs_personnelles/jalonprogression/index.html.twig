{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}Jalons{% endblock %}

{% block content %}
    {% include 'front/gestion_objectifs_personnelles/_flash_messages.html.twig' %}

    <section class="page-header">
        <div>
            <h1>Liste des jalons de progression</h1>
            <p>Recherche par mot-clé, tri par date ou statut, et filtre d’avancement.</p>
        </div>
        <div class="actions">
            <a class="btn btn-secondary" href="{{ path('front_gestion_objectifs_personnelles_index') }}">Retour au module</a>
            <a class="btn btn-primary" href="{{ path('front_jalonprogression_create') }}">Ajouter</a>
        </div>
    </section>

    <form method="get" class="table-card filter-bar">
        <div>
            <label for="jalon_q">Mot-clé</label>
            <input id="jalon_q" type="text" name="q" value="{{ filters.q }}" placeholder="Titre du jalon ou objectif">
        </div>
        <div>
            <label for="jalon_sort">Tri</label>
            <select id="jalon_sort" name="sort">
                {% for label, value in sort_choices %}
                    <option value="{{ value }}" {{ filters.sort == value ? 'selected' : '' }}>{{ label }}</option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label for="jalon_status">Statut</label>
            <select id="jalon_status" name="status">
                <option value="">Tous</option>
                {% for label, value in status_choices %}
                    <option value="{{ value }}" {{ filters.status == value ? 'selected' : '' }}>{{ label }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="actions">
            <button class="btn btn-primary" type="submit">Filtrer</button>
            <a class="btn btn-secondary" href="{{ path('front_jalonprogression_index') }}">Réinitialiser</a>
        </div>
    </form>

    <section class="table-card">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Objectif</th>
                    <th>Titre</th>
                    <th>Date cible</th>
                    <th>Date atteinte</th>
                    <th>Progression</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for jalon in jalons %}
                    <tr>
                        <td>{{ jalon.idJalon }}</td>
                        <td>{{ jalon.idObj.titre }}</td>
                        <td>{{ jalon.titre }}</td>
                        <td>{{ jalon.dateCible|date('d/m/Y') }}</td>
                        <td>{{ jalon.dateAtteinte|date('d/m/Y') }}</td>
                        <td>{{ jalon.pourcentageProgression }}%</td>
                        <td><span class="badge">{{ jalon.atteint ? 'Atteint' : 'En cours' }}</span></td>
                        <td>
                            <div class="inline-actions">
                                <a class="btn btn-secondary" href="{{ path('front_jalonprogression_edit', {idJalon: jalon.idJalon}) }}">Modifier</a>
                                <form method="post" action="{{ path('front_jalonprogression_delete', {idJalon: jalon.idJalon}) }}" onsubmit="return confirm('Supprimer ce jalon ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_jalon_' ~ jalon.idJalon) }}">
                                    <button class="btn btn-danger" type="submit">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="muted">Aucun jalon trouvé.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </section>
{% endblock %}
