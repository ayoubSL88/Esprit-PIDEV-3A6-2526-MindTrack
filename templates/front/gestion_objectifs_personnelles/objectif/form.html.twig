{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}{{ page_title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; flex-wrap: wrap; gap: 16px; }
        .page-header h1 { font-size: 1.8rem; font-weight: 700; background: linear-gradient(135deg, #1e293b, #475569); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin: 0; }
        .page-header p { color: #64748b; margin-top: 8px; }
        .form-card { background: white; border-radius: 24px; padding: 32px; box-shadow: 0 8px 30px rgba(0,0,0,0.05); max-width: 800px; margin: 0 auto; }
        .form-grid { display: flex; flex-direction: column; gap: 24px; }
        .form-grid > div { display: flex; flex-direction: column; gap: 8px; }
        .field-error { color: #ef4444; font-size: 0.75rem; margin-top: 4px; }
        .actions { margin-top: 16px; }
        .btn-primary { background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%); border: none; padding: 12px 28px; border-radius: 40px; font-weight: 600; color: white; cursor: pointer; }
        .btn-secondary { background: #f1f5f9; border: none; padding: 10px 24px; border-radius: 40px; color: #475569; text-decoration: none; font-weight: 500; display: inline-block; }
        .grid { display: grid; gap: 20px; }
    </style>
{% endblock %}

{% block content %}
    {% include 'front/gestion_objectifs_personnelles/_flash_messages.html.twig' %}

    <div style="max-width: 1000px; margin: 0 auto; padding: 20px;">
        <section class="page-header">
            <div>
                <h1>{{ page_title }}</h1>
                <p>Complete les champs requis puis valide le formulaire.</p>
            </div>
            <a class="btn-secondary" href="{{ path('front_objectif_index') }}">Retour a la liste</a>
        </section>

        <section class="form-card">
            {{ form_start(form, {attr: {class: 'form-grid'}}) }}
                {{ form_errors(form) }}
                <div>
                    {{ form_label(form.titre) }}
                    {{ form_widget(form.titre) }}
                    <div class="field-error">{{ form_errors(form.titre) }}</div>
                </div>
                <div>
                    {{ form_label(form.descriprion) }}
                    {{ form_widget(form.descriprion) }}
                    <div class="field-error">{{ form_errors(form.descriprion) }}</div>
                </div>
                <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));">
                    <div>
                        {{ form_label(form.dateDebut) }}
                        {{ form_widget(form.dateDebut) }}
                        <div class="field-error">{{ form_errors(form.dateDebut) }}</div>
                    </div>
                    <div>
                        {{ form_label(form.dateFin) }}
                        {{ form_widget(form.dateFin) }}
                        <div class="field-error">{{ form_errors(form.dateFin) }}</div>
                    </div>
                </div>
                <div>
                    {{ form_label(form.statut) }}
                    {{ form_widget(form.statut) }}
                    <div class="field-error">{{ form_errors(form.statut) }}</div>
                </div>
                <div class="actions">
                    <button class="btn-primary" type="submit">{{ submit_label }}</button>
                </div>
            {{ form_end(form) }}
        </section>
    </div>
{% endblock %}