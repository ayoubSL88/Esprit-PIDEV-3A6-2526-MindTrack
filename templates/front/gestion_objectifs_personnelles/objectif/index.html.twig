{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}Objectifs{% endblock %}

{% block content %}
    {% include 'front/gestion_objectifs_personnelles/_flash_messages.html.twig' %}

    <section class="page-header">
        <div>
            <h1>Liste des objectifs</h1>
            <p>Recherche, tri et filtrage par statut sur tous les objectifs.</p>
        </div>
        <div class="actions">
            <a class="btn btn-secondary" href="{{ path('front_gestion_objectifs_personnelles_index') }}">Retour au module</a>
            <a class="btn btn-primary" href="{{ path('front_objectif_create') }}">Ajouter</a>
        </div>
    </section>

    <form method="get" class="table-card filter-bar">
        <div>
            <label for="objectif_q">Mot-clé</label>
            <input id="objectif_q" type="text" name="q" value="{{ filters.q }}" placeholder="Titre, description, statut">
        </div>
        <div>
            <label for="objectif_sort">Tri</label>
            <select id="objectif_sort" name="sort">
                {% for label, value in sort_choices %}
                    <option value="{{ value }}" {{ filters.sort == value ? 'selected' : '' }}>{{ label }}</option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label for="objectif_status">Statut</label>
            <select id="objectif_status" name="status">
                <option value="">Tous</option>
                {% for label, value in status_choices %}
                    <option value="{{ value }}" {{ filters.status == value ? 'selected' : '' }}>{{ label }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="actions">
            <button class="btn btn-primary" type="submit">Filtrer</button>
            <a class="btn btn-secondary" href="{{ path('front_objectif_index') }}">Réinitialiser</a>
        </div>
    </form>

    <section class="table-card">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Titre</th>
                    <th>Description</th>
                    <th>Début</th>
                    <th>Fin</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for objectif in objectifs %}
                    <tr>
                        <td>{{ objectif.idObj }}</td>
                        <td>{{ objectif.titre }}</td>
                        <td>{{ objectif.descriprion }}</td>
                        <td>{{ objectif.dateDebut|date('d/m/Y') }}</td>
                        <td>{{ objectif.dateFin|date('d/m/Y') }}</td>
                        <td><span class="badge">{{ objectif.statut|replace({'_': ' '})|title }}</span></td>
                        <td>
                            <div class="inline-actions">
                                <a class="btn btn-secondary" href="{{ path('front_objectif_edit', {idObj: objectif.idObj}) }}">Modifier</a>
                                <form method="post" action="{{ path('front_objectif_delete', {idObj: objectif.idObj}) }}" onsubmit="return confirm('Supprimer cet objectif ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_objectif_' ~ objectif.idObj) }}">
                                    <button class="btn btn-danger" type="submit">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="muted">Aucun objectif trouvé.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </section>
{% endblock %}
