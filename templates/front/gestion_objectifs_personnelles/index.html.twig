{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}Gestion des objectifs{% endblock %}

{% block content %}
    <div class="page-stack">
        {{ component('PageHeader', {
            eyebrow: 'Front Office',
            title: 'Mes Objectifs',
            copy: 'Choisissez le module a gerer puis utilisez les ecrans de liste, ajout, modification et suppression.'
        }) }}

        <section class="feature-grid">
            {% for module in modules %}
                <article class="feature-card">
                    <h3 class="feature-title">{{ module.title }}</h3>
                    <p class="feature-copy">{{ module.description }}</p>
                    <a class="btn-primary mt-4" href="{{ path(module.route) }}">Ouvrir</a>
                </article>
            {% endfor %}
        </section>
    </div>
{% endblock %}
