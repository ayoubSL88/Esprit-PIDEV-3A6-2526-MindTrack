{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}Mes Habitudes{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.querySelector('[data-live-filter-form]');
            const results = document.querySelector('[data-live-results]');
            const notifButton = document.querySelector('[data-enable-reminder-notifications]');
            const reminderItems = {{ notificationRappels|json_encode(constant('JSON_UNESCAPED_UNICODE'))|raw }};

            if (!form || !results) {
                return;
            }

            let debounceTimer = null;
            let controller = null;
            let requestId = 0;

            const runLiveFilter = () => {
                const scrollY = window.scrollY;
                const params = new URLSearchParams();

                form.querySelectorAll('input, select').forEach(field => {
                    if (!field.name) {
                        return;
                    }

                    if ((field.type === 'checkbox' || field.type === 'radio') && !field.checked) {
                        return;
                    }

                    params.set(field.name, field.value);
                });

                const historyUrl = `${form.action || window.location.pathname}?${params.toString()}`;
                const fetchParams = new URLSearchParams(params);
                fetchParams.set('_live', String(Date.now()));
                const fetchUrl = `${form.action || window.location.pathname}?${fetchParams.toString()}`;
                const currentRequestId = ++requestId;

                if (controller) {
                    controller.abort();
                }

                controller = new AbortController();
                results.classList.add('opacity-60', 'pointer-events-none');

                fetch(fetchUrl, {
                    cache: 'no-store',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    signal: controller.signal,
                })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Request failed');
                        }

                        return response.text();
                    })
                    .then(html => {
                        if (currentRequestId !== requestId) {
                            return;
                        }

                        results.innerHTML = html;
                        window.history.replaceState({}, '', historyUrl);
                        window.scrollTo({ top: scrollY, behavior: 'auto' });
                    })
                    .catch(error => {
                        if (error.name !== 'AbortError') {
                            console.error(error);
                        }
                    })
                    .finally(() => {
                        if (currentRequestId === requestId) {
                            results.classList.remove('opacity-60', 'pointer-events-none');
                        }
                    });
            };

            form.addEventListener('submit', event => {
                event.preventDefault();
                runLiveFilter();
            });

            form.querySelectorAll('input, select').forEach(field => {
                const eventName = field.tagName === 'SELECT' ? 'change' : 'input';

                field.addEventListener(eventName, () => {
                    clearTimeout(debounceTimer);
                    debounceTimer = setTimeout(runLiveFilter, 220);
                });

                if (field.type === 'search') {
                    field.addEventListener('search', runLiveFilter);
                }
            });

            const dayMap = {
                0: ['DIM', 'DIMANCHE'],
                1: ['LUN', 'LUNDI'],
                2: ['MAR', 'MARDI'],
                3: ['MER', 'MERCREDI'],
                4: ['JEU', 'JEUDI'],
                5: ['VEN', 'VENDREDI'],
                6: ['SAM', 'SAMEDI'],
            };

            const normalizeDayToken = value => value
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .trim()
                .toUpperCase();

            const reminderMatchesNow = reminder => {
                const now = new Date();
                const currentTime = now.toTimeString().slice(0, 5);
                const allowedDays = (reminder.jours || '')
                    .split(',')
                    .map(normalizeDayToken)
                    .filter(Boolean);

                const todayTokens = dayMap[now.getDay()] || [];

                return currentTime === reminder.heure
                    && (allowedDays.length === 0 || todayTokens.some(token => allowedDays.includes(token)));
            };

            const reminderStorageKey = reminder => {
                const now = new Date();
                const yyyy = now.getFullYear();
                const mm = String(now.getMonth() + 1).padStart(2, '0');
                const dd = String(now.getDate()).padStart(2, '0');

                return `mindtrack-rappel-${reminder.id}-${yyyy}-${mm}-${dd}-${reminder.heure}`;
            };

            const triggerReminderNotifications = () => {
                if (!('Notification' in window) || Notification.permission !== 'granted') {
                    return;
                }

                reminderItems.forEach(reminder => {
                    if (!reminderMatchesNow(reminder)) {
                        return;
                    }

                    const storageKey = reminderStorageKey(reminder);
                    if (window.localStorage.getItem(storageKey) === 'sent') {
                        return;
                    }

                    new Notification(`Rappel: ${reminder.habitude}`, {
                        body: reminder.message || `Il est temps de faire votre habitude "${reminder.habitude}".`,
                        tag: `habit-reminder-${reminder.id}`,
                    });

                    window.localStorage.setItem(storageKey, 'sent');
                });
            };

            if (notifButton) {
                const updateNotifButton = () => {
                    if (!('Notification' in window)) {
                        notifButton.textContent = 'Notifications non supportees';
                        notifButton.disabled = true;
                        return;
                    }

                    if (Notification.permission === 'granted') {
                        notifButton.textContent = 'Notifications actives';
                        notifButton.disabled = true;
                        return;
                    }

                    if (Notification.permission === 'denied') {
                        notifButton.textContent = 'Notifications bloquees';
                        notifButton.disabled = true;
                        return;
                    }

                    notifButton.textContent = 'Activer les notifications';
                };

                notifButton.addEventListener('click', async () => {
                    if (!('Notification' in window)) {
                        return;
                    }

                    const permission = await Notification.requestPermission();
                    updateNotifButton();

                    if (permission === 'granted') {
                        triggerReminderNotifications();
                    }
                });

                updateNotifButton();
            }

            triggerReminderNotifications();
            window.setInterval(triggerReminderNotifications, 30000);
        });
    </script>
{% endblock %}

{% block content %}
    <div class="page-stack">
        {% include 'components/quote_widget.html.twig' %}

        {% set weatherTemp = weather.temperature is not null ? weather.temperature|round(0, 'common') : null %}
        {% set weatherBandClass = weatherTemp is null
            ? 'wb-nice'
            : (weatherTemp >= 28
                ? 'wb-hot'
                : (weatherTemp >= 18
                    ? 'wb-nice'
                    : (weatherTemp >= 8 ? 'wb-fresh' : 'wb-cold'))) %}
        {% set weatherIcon = weatherTemp is null
            ? '🌤️'
            : (weather.condition matches '/pluie|orage/i'
                ? '🌧️'
                : (weatherTemp >= 28
                    ? '☀️'
                    : (weatherTemp >= 18
                        ? '🌤️'
                        : (weatherTemp >= 8 ? '🍃' : '❄️')))) %}
        {% set weatherAdvice = weatherTemp is null
            ? 'Chargement de la meteo...'
            : (weatherTemp >= 28
                ? 'Il fait chaud. Bois de l eau et fais 10 min d etirements.'
                : (weatherTemp >= 18
                    ? 'Meteo agreable. Une marche de 15 min serait parfaite.'
                    : (weatherTemp >= 8
                        ? 'Il fait frais. 5 min de respiration + une petite routine a la maison.'
                        : 'Il fait froid. Reste au chaud : 5 min de meditation + planifie tes habitudes.'))) %}

        <div id="weather-band" class="wb-band {{ weatherBandClass }}">
            <span class="wb-icon" aria-hidden="true">{{ weatherIcon }}</span>

            <div class="wb-city-block">
                <div class="wb-temp">{{ weatherTemp is not null ? weatherTemp ~ '°C' : '--°C' }}</div>
                <div class="wb-city">{{ weather.locationLabel }}</div>
            </div>

            <div class="wb-sep"></div>

            <div class="wb-metas">
                <div class="wb-meta-item">
                    <span class="wb-meta-val">{{ weather.humidity is not null ? weather.humidity ~ '%' : '--' }}</span>
                    <span class="wb-meta-key">Humidite</span>
                </div>
                <div class="wb-meta-item">
                    <span class="wb-meta-val">{{ weather.windSpeed is not null ? weather.windSpeed|round(0, 'common') ~ ' km/h' : '--' }}</span>
                    <span class="wb-meta-key">Vent</span>
                </div>
            </div>

            <div class="wb-sep2"></div>

            <div class="wb-advice">{{ weatherAdvice }}</div>

            <a href="{{ path('front_gestion_suivi_habitudes_index') }}" class="wb-link">Voir meteo ›</a>
        </div>

        <div class="button-row">
            <a class="btn-primary" href="{{ path('front_gestion_suivi_habitudes_habitude_new') }}">Nouvelle habitude</a>
            <a class="btn-secondary" href="{{ path('front_gestion_suivi_habitudes_suivi_new') }}">Ajouter un suivi</a>
            <a class="btn-secondary" href="{{ path('front_gestion_suivi_habitudes_export_pdf') }}">Exporter PDF</a>
            <a class="btn-secondary" href="{{ path('front_gestion_suivi_habitudes_rappel_new') }}">Programmer un rappel</a>
            <button class="btn-secondary" type="button" data-enable-reminder-notifications>Activer les notifications</button>
        </div>

        <form method="get" class="panel-section grid gap-4 lg:grid-cols-6 lg:items-end" data-live-filter-form>
            <input class="field-input" type="text" name="q" placeholder="Rechercher une habitude, un objectif..." value="{{ filters.q }}">
            <select class="field-select" name="frequence"><option value="">Toutes les frequences</option><option value="QUOTIDIEN" {{ filters.frequence == 'QUOTIDIEN' ? 'selected' : '' }}>Quotidien</option><option value="HEBDOMADAIRE" {{ filters.frequence == 'HEBDOMADAIRE' ? 'selected' : '' }}>Hebdomadaire</option><option value="MENSUEL" {{ filters.frequence == 'MENSUEL' ? 'selected' : '' }}>Mensuel</option></select>
            <select class="field-select" name="type"><option value="">Tous les types</option><option value="BOOLEAN" {{ filters.habitType == 'BOOLEAN' ? 'selected' : '' }}>Booleen</option><option value="NUMERIC" {{ filters.habitType == 'NUMERIC' ? 'selected' : '' }}>Numerique</option></select>
            <select class="field-select" name="sort"><option value="nom" {{ filters.sort == 'nom' ? 'selected' : '' }}>Trier par nom</option><option value="objectif" {{ filters.sort == 'objectif' ? 'selected' : '' }}>Trier par objectif</option><option value="frequence" {{ filters.sort == 'frequence' ? 'selected' : '' }}>Trier par frequence</option><option value="target" {{ filters.sort == 'target' ? 'selected' : '' }}>Trier par valeur cible</option><option value="type" {{ filters.sort == 'type' ? 'selected' : '' }}>Trier par type</option></select>
            <select class="field-select" name="direction"><option value="" {{ filters.direction == '' ? 'selected' : '' }}>Choisir l'ordre</option><option value="ASC" {{ filters.direction == 'ASC' ? 'selected' : '' }}>Ordre croissant</option><option value="DESC" {{ filters.direction == 'DESC' ? 'selected' : '' }}>Ordre decroissant</option></select>
            <button class="btn-primary" type="submit">Filtrer</button>
        </form>

        {{ component('FlashStack') }}

        <section class="feature-grid">
            <article class="feature-card"><p class="feature-label">Habitudes actives</p><p class="feature-title">{{ stats.habitudes }}</p></article>
            <article class="feature-card"><p class="feature-label">Rappels actifs</p><p class="feature-title">{{ stats.rappels_actifs }}</p></article>
            <article class="feature-card"><p class="feature-label">Suivis completes</p><p class="feature-title">{{ stats.suivis_completed }}</p></article>
            <article class="feature-card"><p class="feature-label">Suivis total</p><p class="feature-title">{{ stats.suivis_total }}</p></article>
        </section>

       <section class="mt-overview-section">
    <div class="mt-overview-grid">

        {# COLONNE GAUCHE : KPIs + légende #}
        <div class="mt-left-col">

            {# Bloc principal KPIs #}
            <div class="mt-kpi-panel">
                <p class="mt-section-eyebrow">Tableau de bord</p>
                <h2 class="mt-section-title">Vue rapide pour mieux piloter vos habitudes</h2>
                <p class="mt-section-desc">Les indicateurs les plus importants sont regroupés ici pour voir tout de suite ce qui va bien, ce qui ralentit et ce qu'il faut corriger aujourd'hui.</p>

                <div class="mt-kpi-grid">
                    <article class="mt-kpi-card mt-kpi-neutral">
                        <p class="mt-kpi-label">Meilleure série</p>
                        <p class="mt-kpi-value">{{ advancedSummary.bestStreak }}</p>
                        <p class="mt-kpi-sub">jours consécutifs</p>
                    </article>
                    <article class="mt-kpi-card mt-kpi-warning">
                        <p class="mt-kpi-label">À surveiller</p>
                        <p class="mt-kpi-value">{{ advancedSummary.highRiskHabits }}</p>
                        <p class="mt-kpi-sub">habitudes à risque élevé</p>
                    </article>
                    <article class="mt-kpi-card mt-kpi-success">
                        <p class="mt-kpi-label">En contrôle</p>
                        <p class="mt-kpi-value">{{ advancedSummary.stableHabits }}</p>
                        <p class="mt-kpi-sub">habitudes stables</p>
                    </article>
                </div>
            </div>

            {# Légende des couleurs #}
            <article class="mt-legend-card">
                <p class="mt-legend-eyebrow">Lecture rapide</p>
                <ul class="mt-legend-list">
                    <li>
                        <span class="mt-dot mt-dot-green"></span>
                        <span>Le vert indique une routine stable ou une progression solide.</span>
                    </li>
                    <li>
                        <span class="mt-dot mt-dot-amber"></span>
                        <span>L'orange attire l'attention sur les habitudes à reprendre vite.</span>
                    </li>
                    <li>
                        <span class="mt-dot mt-dot-blue"></span>
                        <span>Les recommandations et rappels intelligents donnent l'action à faire ensuite.</span>
                    </li>
                </ul>
            </article>
        </div>

        {# COLONNE DROITE : Badges #}
        <article class="mt-badges-card">
            <div class="mt-badges-head">
                <div>
                    <p class="mt-badges-eyebrow">Récompenses</p>
                    <h3 class="mt-badges-title">Badges débloqués</h3>
                </div>
                <span class="mt-badges-count">{{ badges|length }}</span>
            </div>

            {% if badges is empty %}
                <p class="mt-badges-empty">Aucun badge pour le moment. Une routine plus régulière fera remonter ici vos premières récompenses.</p>
            {% else %}
                <div class="mt-badges-list">
                    {% for badge in badges|slice(0, 3) %}
                        <div class="mt-badge-item">
                            <div class="mt-badge-item-header">
                                <p class="mt-badge-habit">{{ badge.habitName }}</p>
                                <span class="mt-badge-pill">{{ badge.badge|replace({'_': ' '}) }}</span>
                            </div>
                            <p class="mt-badge-reason">{{ badge.reason }}</p>
                        </div>
                    {% endfor %}
                    {% if badges|length > 3 %}
                        <p class="mt-badges-more">+{{ badges|length - 3 }} badge(s) supplémentaire(s)</p>
                    {% endif %}
                </div>
            {% endif %}
        </article>

    </div>
</section>

        <section class="hero-grid">
            <article class="panel-section">
                <h2 class="panel-title">Mes habitudes</h2>
                <p class="panel-copy">Gardez un oeil sur vos objectifs et adaptez-les facilement.</p>
                <div data-live-results class="mt-4">
                    {% include 'front/gestion_suivi_habitudes/_habitudes_results.html.twig' with { habitudes: habitudes, advancedInsights: advancedInsights } %}
                </div>
            </article>

            <div class="page-stack">
                <aside class="panel-section">
                    <h2 class="panel-title">Rappels du moment</h2>
                    {% if todayRappels is empty %}
                        <p class="table-empty mt-3">Aucun rappel actif pour le moment.</p>
                    {% else %}
                        <div class="mt-3 space-y-3">
                            {% for rappel in todayRappels %}
                                <div class="rounded-2xl border border-border bg-white/80 p-4">
                                    <p class="text-sm font-semibold text-ink">{{ rappel.idHabitude ? rappel.idHabitude.nom : 'Habitude' }}</p>
                                    <p class="mt-1 text-sm text-muted">{{ rappel.message }}</p>
                                    <p class="mt-1 text-xs text-muted">{{ rappel.jours }} a {{ rappel.heureRappel }}</p>
                                    <div class="button-row mt-3">
                                        <a class="btn-secondary px-4 py-2" href="{{ path('front_gestion_suivi_habitudes_rappel_edit', {idRappel: rappel.idRappel}) }}">Modifier</a>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </aside>

                <aside class="panel-section">
                    <h2 class="panel-title">Progression du jour</h2>
                    {% if todaySuivis is empty %}
                        <p class="table-empty mt-3">Aucun suivi enregistre aujourd hui.</p>
                    {% else %}
                        <div class="mt-3 space-y-3">
                            {% for suivi in todaySuivis %}
                                <div class="rounded-2xl border border-border bg-white/80 p-4">
                                    <p class="text-sm font-semibold text-ink">{{ suivi.idHabitude ? suivi.idHabitude.nom : 'Habitude' }}</p>
                                    <p class="mt-1 text-sm text-muted">{{ suivi.etat ? 'Objectif atteint' : 'Encore en cours' }}</p>
                                    <p class="mt-1 text-xs text-muted">Valeur du jour : {{ suivi.valeur }}</p>
                                    <div class="button-row mt-3">
                                        <a class="btn-secondary px-4 py-2" href="{{ path('front_gestion_suivi_habitudes_suivi_edit', {idSuivi: suivi.idSuivi}) }}">Modifier</a>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </aside>

                <aside class="panel-section">
                    <h2 class="panel-title">Historique recent</h2>
                    {% if recentSuivis is empty %}
                        <p class="table-empty mt-3">Aucun historique disponible.</p>
                    {% else %}
                        <div class="mt-3 space-y-3">
                            {% for suivi in recentSuivis %}
                                <div class="rounded-2xl border border-border bg-white/80 p-4">
                                    <p class="text-sm font-semibold text-ink">{{ suivi.idHabitude ? suivi.idHabitude.nom : 'Habitude' }}</p>
                                    <p class="mt-1 text-xs text-muted">{{ suivi.date ? suivi.date|date('d/m/Y') : '' }}</p>
                                    <p class="mt-1 text-sm text-muted">{{ suivi.etat ? 'Complete' : 'Non complete' }} - Valeur {{ suivi.valeur }}</p>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </aside>
            </div>
        </section>
    </div>
{% endblock %}

{% block floating_widgets %}
    {% include 'components/chatbot_bubble.html.twig' %}
{% endblock %}
