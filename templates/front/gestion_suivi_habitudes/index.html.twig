{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}Mes Habitudes{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .hero { position: relative; overflow: hidden; padding: 2.2rem; border-radius: 30px; background: radial-gradient(circle at top left, rgba(255,255,255,.7), transparent 32%), linear-gradient(135deg, #f7c873 0%, #f4e3b2 35%, #fff9ea 100%); border: 1px solid #eed7a2; box-shadow: 0 30px 90px rgba(190, 143, 40, .16); }
        .hero h1 { margin: 0 0 .6rem; font-size: clamp(2rem, 4vw, 3.2rem); color: #4d3810; }
        .hero p { max-width: 720px; color: #6a5630; }
        .hero-actions, .quick-actions, .filter-row, .card-actions { display: flex; gap: .75rem; flex-wrap: wrap; }
        .hero-actions { margin-top: 1.25rem; }
        .btn { display: inline-flex; align-items: center; justify-content: center; padding: .85rem 1.15rem; border-radius: 999px; text-decoration: none; border: none; cursor: pointer; font: inherit; font-weight: 700; }
        .btn-primary { color: #fff; background: linear-gradient(135deg, #bc8a28 0%, #dfb55f 100%); }
        .btn-soft { color: #5f4a1c; background: rgba(255,255,255,.7); }
        .btn-danger { color: #fff; background: #b54708; }
        .btn-notif { color: #5b4210; background: rgba(255,255,255,.88); }
        .stats-grid, .layout-grid, .habit-grid { display: grid; gap: 1rem; }
        .stats-grid { grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); margin-top: 1.4rem; }
        .layout-grid { grid-template-columns: 1.4fr .95fr; margin-top: 2rem; align-items: start; }
        .stat-card, .panel, .habit-card { border-radius: 24px; background: linear-gradient(180deg, #ffffff 0%, #fffaf0 100%); border: 1px solid #ece1c8; box-shadow: 0 18px 48px rgba(175, 132, 45, .09); }
        .stat-card { padding: 1.15rem; }
        .stat-label { display: block; color: #7d6c46; font-size: .88rem; margin-bottom: .35rem; }
        .stat-value { font-size: 2rem; font-weight: 800; color: #4f3911; }
        .panel { padding: 1.4rem; }
        .panel h2 { margin-top: 0; color: #4f3911; }
        .filter-box { margin-top: 1.4rem; padding: 1.2rem; border-radius: 22px; background: rgba(255,255,255,.55); border: 1px solid rgba(164, 123, 32, .15); }
        .filter-row input, .filter-row select { flex: 1 1 160px; min-width: 0; padding: .85rem .95rem; border-radius: 16px; border: 1px solid #e2d4b7; background: #fffdf7; font: inherit; }
        .habit-grid { grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); margin-top: 1.2rem; }
        .habit-card { padding: 1.2rem; }
        .habit-card h3 { margin: 0 0 .35rem; color: #3f2d0c; }
        .habit-meta { display: flex; gap: .55rem; flex-wrap: wrap; margin-bottom: .9rem; }
        .pill { display: inline-flex; align-items: center; padding: .35rem .7rem; border-radius: 999px; font-size: .8rem; font-weight: 700; }
        .pill-gold { background: #fff0c8; color: #805f16; }
        .pill-green { background: #dff7e4; color: #1d6a31; }
        .list { display: grid; gap: .8rem; }
        .list-item { padding: 1rem; border-radius: 18px; background: #fffdf8; border: 1px solid #ede3d0; }
        .list-item strong { color: #3f2d0c; }
        .muted { color: #7b6b48; }
        .flash { margin-top: 1rem; padding: 1rem 1.15rem; border-radius: 16px; background: #f4fff3; color: #215c29; border: 1px solid #d3ead1; }
        .empty { padding: 1rem; border-radius: 18px; background: #fffdf7; border: 1px dashed #e1d3b4; color: #7b6b48; }
        .inline-form { display: inline; }
        .results-loading { opacity: .55; pointer-events: none; transition: opacity .2s ease; }
        @media (max-width: 920px) { .layout-grid { grid-template-columns: 1fr; } }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.querySelector('[data-live-filter-form]');
            const results = document.querySelector('[data-live-results]');
            const notifButton = document.querySelector('[data-enable-reminder-notifications]');
            const reminderItems = {{ notificationRappels|json_encode(constant('JSON_UNESCAPED_UNICODE'))|raw }};

            if (!form || !results) {
                return;
            }

            let debounceTimer = null;
            let controller = null;
            let requestId = 0;

            const runLiveFilter = () => {
                const scrollY = window.scrollY;
                const params = new URLSearchParams();

                form.querySelectorAll('input, select').forEach(field => {
                    if (!field.name) {
                        return;
                    }

                    if ((field.type === 'checkbox' || field.type === 'radio') && !field.checked) {
                        return;
                    }

                    params.set(field.name, field.value);
                });

                const historyUrl = `${form.action || window.location.pathname}?${params.toString()}`;
                const fetchParams = new URLSearchParams(params);
                fetchParams.set('_live', String(Date.now()));
                const fetchUrl = `${form.action || window.location.pathname}?${fetchParams.toString()}`;
                const currentRequestId = ++requestId;

                if (controller) {
                    controller.abort();
                }

                controller = new AbortController();
                results.classList.add('results-loading');

                fetch(fetchUrl, {
                    cache: 'no-store',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    signal: controller.signal,
                })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Request failed');
                        }

                        return response.text();
                    })
                    .then(html => {
                        if (currentRequestId !== requestId) {
                            return;
                        }

                        results.innerHTML = html;
                        window.history.replaceState({}, '', historyUrl);
                        window.scrollTo({ top: scrollY, behavior: 'auto' });
                    })
                    .catch(error => {
                        if (error.name !== 'AbortError') {
                            console.error(error);
                        }
                    })
                    .finally(() => {
                        if (currentRequestId === requestId) {
                            results.classList.remove('results-loading');
                        }
                    });
            };

            form.addEventListener('submit', event => {
                event.preventDefault();
                runLiveFilter();
            });

            form.querySelectorAll('input, select').forEach(field => {
                const eventName = field.tagName === 'SELECT' ? 'change' : 'input';

                field.addEventListener(eventName, () => {
                    clearTimeout(debounceTimer);
                    debounceTimer = setTimeout(runLiveFilter, 220);
                });

                if (field.type === 'search') {
                    field.addEventListener('search', runLiveFilter);
                }
            });

            const dayMap = {
                0: ['DIM', 'DIMANCHE'],
                1: ['LUN', 'LUNDI'],
                2: ['MAR', 'MARDI'],
                3: ['MER', 'MERCREDI'],
                4: ['JEU', 'JEUDI'],
                5: ['VEN', 'VENDREDI'],
                6: ['SAM', 'SAMEDI'],
            };

            const normalizeDayToken = value => value
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .trim()
                .toUpperCase();

            const reminderMatchesNow = reminder => {
                const now = new Date();
                const currentTime = now.toTimeString().slice(0, 5);
                const allowedDays = (reminder.jours || '')
                    .split(',')
                    .map(normalizeDayToken)
                    .filter(Boolean);

                const todayTokens = dayMap[now.getDay()] || [];

                return currentTime === reminder.heure
                    && (allowedDays.length === 0 || todayTokens.some(token => allowedDays.includes(token)));
            };

            const reminderStorageKey = reminder => {
                const now = new Date();
                const yyyy = now.getFullYear();
                const mm = String(now.getMonth() + 1).padStart(2, '0');
                const dd = String(now.getDate()).padStart(2, '0');

                return `mindtrack-rappel-${reminder.id}-${yyyy}-${mm}-${dd}-${reminder.heure}`;
            };

            const triggerReminderNotifications = () => {
                if (!('Notification' in window) || Notification.permission !== 'granted') {
                    return;
                }

                reminderItems.forEach(reminder => {
                    if (!reminderMatchesNow(reminder)) {
                        return;
                    }

                    const storageKey = reminderStorageKey(reminder);
                    if (window.localStorage.getItem(storageKey) === 'sent') {
                        return;
                    }

                    new Notification(`Rappel: ${reminder.habitude}`, {
                        body: reminder.message || `Il est temps de faire votre habitude "${reminder.habitude}".`,
                        tag: `habit-reminder-${reminder.id}`,
                    });

                    window.localStorage.setItem(storageKey, 'sent');
                });
            };

            if (notifButton) {
                const updateNotifButton = () => {
                    if (!('Notification' in window)) {
                        notifButton.textContent = 'Notifications non supportees';
                        notifButton.disabled = true;
                        return;
                    }

                    if (Notification.permission === 'granted') {
                        notifButton.textContent = 'Notifications actives';
                        notifButton.disabled = true;
                        return;
                    }

                    if (Notification.permission === 'denied') {
                        notifButton.textContent = 'Notifications bloquees';
                        notifButton.disabled = true;
                        return;
                    }

                    notifButton.textContent = 'Activer les notifications';
                };

                notifButton.addEventListener('click', async () => {
                    if (!('Notification' in window)) {
                        return;
                    }

                    const permission = await Notification.requestPermission();
                    updateNotifButton();

                    if (permission === 'granted') {
                        triggerReminderNotifications();
                    }
                });

                updateNotifButton();
            }

            triggerReminderNotifications();
            window.setInterval(triggerReminderNotifications, 30000);
        });
    </script>
{% endblock %}

{% block content %}
    <section class="hero">
        <h1>Construisez votre routine</h1>
        <p>Suivez vos habitudes, gardez vos rappels visibles et mesurez votre progression sans quitter votre espace personnel.</p>
        <div class="hero-actions">
            <a class="btn btn-primary" href="{{ path('front_gestion_suivi_habitudes_habitude_new') }}">Nouvelle habitude</a>
            <a class="btn btn-soft" href="{{ path('front_gestion_suivi_habitudes_suivi_new') }}">Ajouter un suivi</a>
            <a class="btn btn-soft" href="{{ path('front_gestion_suivi_habitudes_rappel_new') }}">Programmer un rappel</a>
            <button class="btn btn-notif" type="button" data-enable-reminder-notifications>Activer les notifications</button>
        </div>

        <form method="get" class="filter-box" data-live-filter-form>
            <div class="filter-row">
                <input type="text" name="q" placeholder="Rechercher une habitude, un objectif..." value="{{ filters.q }}">
                <select name="frequence">
                    <option value="">Toutes les frequences</option>
                    <option value="QUOTIDIEN" {{ filters.frequence == 'QUOTIDIEN' ? 'selected' : '' }}>Quotidien</option>
                    <option value="HEBDOMADAIRE" {{ filters.frequence == 'HEBDOMADAIRE' ? 'selected' : '' }}>Hebdomadaire</option>
                    <option value="MENSUEL" {{ filters.frequence == 'MENSUEL' ? 'selected' : '' }}>Mensuel</option>
                </select>
                <select name="type">
                    <option value="">Tous les types</option>
                    <option value="BOOLEAN" {{ filters.habitType == 'BOOLEAN' ? 'selected' : '' }}>Booleen</option>
                    <option value="NUMERIC" {{ filters.habitType == 'NUMERIC' ? 'selected' : '' }}>Numerique</option>
                </select>
                <select name="sort">
                    <option value="nom" {{ filters.sort == 'nom' ? 'selected' : '' }}>Trier par nom</option>
                    <option value="objectif" {{ filters.sort == 'objectif' ? 'selected' : '' }}>Trier par objectif</option>
                    <option value="frequence" {{ filters.sort == 'frequence' ? 'selected' : '' }}>Trier par frequence</option>
                    <option value="target" {{ filters.sort == 'target' ? 'selected' : '' }}>Trier par valeur cible</option>
                    <option value="type" {{ filters.sort == 'type' ? 'selected' : '' }}>Trier par type</option>
                </select>
                <select name="direction">
                    <option value="" {{ filters.direction == '' ? 'selected' : '' }}>Choisir l'ordre</option>
                    <option value="ASC" {{ filters.direction == 'ASC' ? 'selected' : '' }}>Ordre croissant</option>
                    <option value="DESC" {{ filters.direction == 'DESC' ? 'selected' : '' }}>Ordre decroissant</option>
                </select>
                <button class="btn btn-primary" type="submit">Filtrer</button>
            </div>
        </form>
    </section>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <section class="stats-grid">
        <article class="stat-card"><span class="stat-label">Habitudes actives</span><strong class="stat-value">{{ stats.habitudes }}</strong></article>
        <article class="stat-card"><span class="stat-label">Rappels actifs</span><strong class="stat-value">{{ stats.rappels_actifs }}</strong></article>
        <article class="stat-card"><span class="stat-label">Suivis completes</span><strong class="stat-value">{{ stats.suivis_completed }}</strong></article>
        <article class="stat-card"><span class="stat-label">Suivis total</span><strong class="stat-value">{{ stats.suivis_total }}</strong></article>
    </section>

    <section class="layout-grid">
        <div>
            <div class="panel">
                <h2>Mes habitudes</h2>
                <p class="muted">Gardez un oeil sur vos objectifs et adaptez-les facilement.</p>
                <div data-live-results>
                    {% include 'front/gestion_suivi_habitudes/_habitudes_results.html.twig' with { habitudes: habitudes } %}
                </div>
            </div>
        </div>

        <div class="list">
            <aside class="panel">
                <h2>Rappels du moment</h2>
                {% if todayRappels is empty %}
                    <div class="empty">Aucun rappel actif pour le moment.</div>
                {% else %}
                    {% for rappel in todayRappels %}
                        <div class="list-item">
                            <strong>{{ rappel.idHabitude ? rappel.idHabitude.nom : 'Habitude' }}</strong>
                            <p class="muted">{{ rappel.message }}</p>
                            <p>{{ rappel.jours }} a {{ rappel.heureRappel }}</p>
                            <div class="card-actions">
                                <a class="btn btn-soft" href="{{ path('front_gestion_suivi_habitudes_rappel_edit', {idRappel: rappel.idRappel}) }}">Modifier</a>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </aside>

            <aside class="panel">
                <h2>Progression du jour</h2>
                {% if todaySuivis is empty %}
                    <div class="empty">Aucun suivi enregistre aujourd hui.</div>
                {% else %}
                    {% for suivi in todaySuivis %}
                        <div class="list-item">
                            <strong>{{ suivi.idHabitude ? suivi.idHabitude.nom : 'Habitude' }}</strong>
                            <p class="muted">{{ suivi.etat ? 'Objectif atteint' : 'Encore en cours' }}</p>
                            <p>Valeur du jour : {{ suivi.valeur }}</p>
                            <div class="card-actions">
                                <a class="btn btn-soft" href="{{ path('front_gestion_suivi_habitudes_suivi_edit', {idSuivi: suivi.idSuivi}) }}">Modifier</a>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </aside>

            <aside class="panel">
                <h2>Historique recent</h2>
                {% if recentSuivis is empty %}
                    <div class="empty">Aucun historique disponible.</div>
                {% else %}
                    {% for suivi in recentSuivis %}
                        <div class="list-item">
                            <strong>{{ suivi.idHabitude ? suivi.idHabitude.nom : 'Habitude' }}</strong>
                            <p class="muted">{{ suivi.date ? suivi.date|date('d/m/Y') : '' }}</p>
                            <p>{{ suivi.etat ? 'Complete' : 'Non complete' }} - Valeur {{ suivi.valeur }}</p>
                        </div>
                    {% endfor %}
                {% endif %}
            </aside>
        </div>
    </section>
{% endblock %}
