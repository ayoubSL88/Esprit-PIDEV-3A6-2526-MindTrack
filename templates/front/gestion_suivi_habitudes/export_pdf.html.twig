<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Export PDF Habitudes</title>
    <style>
        body {
            font-family: DejaVu Sans, sans-serif;
            color: #1f2937;
            font-size: 12px;
            line-height: 1.45;
            margin: 24px;
        }

        h1, h2, h3, p {
            margin: 0;
        }

        .header {
            border-bottom: 2px solid #4f46e5;
            padding-bottom: 12px;
            margin-bottom: 20px;
        }

        .title {
            font-size: 24px;
            color: #312e81;
            margin-bottom: 6px;
        }

        .muted {
            color: #6b7280;
        }

        .habit-card {
            border: 1px solid #d1d5db;
            border-radius: 10px;
            padding: 14px;
            margin-bottom: 16px;
        }

        .habit-name {
            font-size: 16px;
            color: #111827;
            margin-bottom: 8px;
        }

        .grid {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        .grid td {
            border: 1px solid #e5e7eb;
            padding: 8px;
            vertical-align: top;
        }

        .label {
            width: 26%;
            font-weight: bold;
            background: #f9fafb;
        }

        .section {
            margin-top: 12px;
        }

        .section-title {
            font-size: 13px;
            color: #4338ca;
            margin-bottom: 6px;
        }

        .empty {
            border: 1px dashed #cbd5e1;
            padding: 18px;
            border-radius: 10px;
            background: #f8fafc;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1 class="title">Export des habitudes</h1>
        <p class="muted">Utilisateur : {{ user.prenomU }} {{ user.nomU }}</p>
        <p class="muted">Genere le {{ generatedAt|date('d/m/Y H:i') }}</p>
    </div>

    {% if habitudes is empty %}
        <div class="empty">
            <p>Aucune habitude a exporter pour le moment.</p>
        </div>
    {% else %}
        {% for habitude in habitudes %}
            {% set insight = advancedInsights[habitude.idHabitude] ?? {} %}
            {% set progress = insight.progress ?? {} %}
            {% set streak = insight.streak ?? {} %}
            {% set risk = insight.risk ?? {} %}
            {% set recommendation = insight.recommendation ?? {} %}
            {% set moodCorrelation = insight.moodCorrelation ?? {} %}

            <div class="habit-card">
                <h2 class="habit-name">{{ habitude.nom }}</h2>

                <table class="grid">
                    <tr>
                        <td class="label">Frequence</td>
                        <td>{{ habitude.frequence }}</td>
                        <td class="label">Type</td>
                        <td>{{ habitude.habitType }}</td>
                    </tr>
                    <tr>
                        <td class="label">Objectif</td>
                        <td>{{ habitude.objectif }}</td>
                        <td class="label">Valeur cible</td>
                        <td>{{ habitude.targetValue }} {{ habitude.unit }}</td>
                    </tr>
                    <tr>
                        <td class="label">Progression moyenne</td>
                        <td>{{ progress.averageTargetReach ?? 0 }}%</td>
                        <td class="label">Taux de completion</td>
                        <td>{{ progress.completionRate ?? 0 }}%</td>
                    </tr>
                    <tr>
                        <td class="label">Serie actuelle</td>
                        <td>{{ streak.currentStreak ?? 0 }}</td>
                        <td class="label">Meilleure serie</td>
                        <td>{{ streak.bestStreak ?? 0 }}</td>
                    </tr>
                    <tr>
                        <td class="label">Niveau de risque</td>
                        <td>{{ risk.riskLevel ?? 'N/A' }}</td>
                        <td class="label">Jours depuis suivi</td>
                        <td>{{ risk.daysSinceLastTrack ?? 'N/A' }}</td>
                    </tr>
                </table>

                <div class="section">
                    <h3 class="section-title">Recommandations</h3>
                    <p>{{ recommendation.recommendations is defined and recommendation.recommendations is not empty ? recommendation.recommendations|join(' ') : 'Aucune recommandation disponible.' }}</p>
                </div>

                <div class="section">
                    <h3 class="section-title">Correlation humeur</h3>
                    <p>
                        Humeur moyenne avec habitude : {{ moodCorrelation.averageMoodWithHabit ?? 'N/A' }}
                        |
                        sans habitude : {{ moodCorrelation.averageMoodWithoutHabit ?? 'N/A' }}
                    </p>
                </div>
            </div>
        {% endfor %}
    {% endif %}
</body>
</html>
