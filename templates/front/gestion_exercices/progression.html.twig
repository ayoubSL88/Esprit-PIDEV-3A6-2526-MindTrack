{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}Ma progression{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* Styles personnalisés */
    .gradient-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    
    /* Carte de conseil bien-être */
    .wellness-advice {
        margin-bottom: 2rem;
    }
    
    .advice-card {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        border-radius: 15px;
        padding: 1.5rem;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        transition: transform 0.3s ease;
    }
    
    .advice-card:hover {
        transform: translateY(-5px);
    }
    
    .advice-text {
        font-size: 1.2rem;
        font-style: italic;
        color: #2c3e50;
        margin-bottom: 0.5rem;
        line-height: 1.6;
    }
    
    .advice-text::before {
        content: "« ";
        font-size: 1.5rem;
        color: #764ba2;
    }
    
    .advice-text::after {
        content: " »";
        font-size: 1.5rem;
        color: #764ba2;
    }
    
    .advice-source {
        color: #6c757d;
        font-size: 0.9rem;
        display: block;
        text-align: right;
    }
    
    /* Cartes de statistiques */
    .stat-card {
        transition: transform 0.2s;
    }
    
    .stat-card:hover {
        transform: translateY(-5px);
    }
    
    .stat-icon {
        font-size: 2rem;
        margin-bottom: 0.5rem;
    }
    
    /* Animation pour la progression */
    .progress-bar {
        transition: width 1s ease-in-out;
    }
    
    /* Responsive */
    @media (max-width: 768px) {
        .advice-text {
            font-size: 1rem;
        }
        
        .stat-card {
            margin-bottom: 1rem;
        }
    }
</style>
{% endblock %}

{% block content %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
        <h1>
            <i class="bi bi-graph-up text-success"></i> 
            Ma progression
        </h1>
        <a href="{{ path('front_gestion_exercices_home') }}" class="btn btn-outline-primary mt-2 mt-sm-0">
            <i class="bi bi-arrow-left"></i> Retour à l'espace d'exercices
        </a>

    </div>

    <!-- Conseil bien-être du jour -->
    {% if advice is defined and advice is not empty %}
    <div class="wellness-advice">
        <div class="advice-card">
            <h5 class="mb-3">
                <i class="bi bi-flower1 text-primary"></i> 
                Conseil bien-être du jour
            </h5>
            <p class="advice-text">{{ advice }}</p>
            <small class="advice-source">
                <i class="bi bi-chat-quote"></i> AdviceSlip API
            </small>
        </div>
    </div>
    {% endif %}

    <!-- Bouton d'export PDF -->
    <div class="text-end mb-4">
        <a href="{{ path('front_progression_export_pdf') }}" class="btn btn-danger" target="_blank">
            <i class="bi bi-file-pdf"></i> Exporter ma progression en PDF
        </a>
    </div>

    <!-- Progression globale -->
    <div class="card shadow-sm mb-4">
        <div class="card-header gradient-primary text-white">
            <h5 class="mb-0"><i class="bi bi-trophy-fill"></i> Vue d'ensemble</h5>
        </div>
        <div class="card-body">
            <div class="row text-center">
                <div class="col-md-4 mb-3 mb-md-0">
                    <div class="border-end-md">
                        <div class="stat-icon">
                            <i class="bi bi-check-circle-fill text-primary"></i>
                        </div>
                        <h6 class="text-muted">Exercices terminés</h6>
                        <h2 class="text-primary">{{ global_progression.sessionsTerminees|default(0) }}</h2>
                    </div>
                </div>
                <div class="col-md-4 mb-3 mb-md-0">
                    <div class="border-end-md">
                        <div class="stat-icon">
                            <i class="bi bi-clock-fill text-success"></i>
                        </div>
                        <h6 class="text-muted">Temps total passé</h6>
                        <h2 class="text-success">{{ (global_progression.tempsTotal|default(0) / 60)|round }} min</h2>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-icon">
                        <i class="bi bi-graph-up text-info"></i>
                    </div>
                    <h6 class="text-muted">Progression moyenne</h6>
                    <h2 class="text-info">
                        {% set avg = 0 %}
                        {% for item in sessions_by_exercice %}
                            {% set avg = avg + item.moyenne_progression %}
                        {% endfor %}
                        {{ sessions_by_exercice|length > 0 ? (avg / sessions_by_exercice|length)|round : 0 }}%
                    </h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Graphique d'évolution -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0"><i class="bi bi-calendar-week"></i> Évolution des exercices (7 derniers jours)</h5>
        </div>
        <div class="card-body">
            <canvas id="evolutionChart" height="100"></canvas>
        </div>
    </div>

    <!-- Progression par exercice -->
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0"><i class="bi bi-bar-chart-steps"></i> Progression par exercice</h5>
        </div>
        <div class="card-body">
            {% if sessions_by_exercice is empty or sessions_by_exercice|filter(item => item.total_sessions > 0)|length == 0 %}
                <div class="text-center py-5">
                    <i class="bi bi-emoji-frown fs-1 text-muted"></i>
                    <h4 class="mt-3">Aucune activité pour le moment</h4>
                    <p>Commencez un exercice pour suivre votre progression ici.</p>
                    <a href="{{ path('front_gestion_exercices_index') }}" class="btn btn-primary">
                        <i class="bi bi-play-fill"></i> Découvrir les exercices
                    </a>
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Exercice</th>
                                <th>Type</th>
                                <th>Difficulté</th>
                                <th>Sessions</th>
                                <th>Progression moyenne</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in sessions_by_exercice %}
                                {% if item.total_sessions > 0 %}
                                <tr>
                                    <td>
                                        <strong>{{ item.exercice.nom }}</strong>
                                    </td>
                                    <td>{{ item.exercice.type }}</td>
                                    <td>
                                        <span class="badge bg-{{ item.exercice.difficulte == 'FACILE' ? 'success' : (item.exercice.difficulte == 'MOYEN' ? 'warning' : 'danger') }}">
                                            {{ item.exercice.difficulte }}
                                        </span>
                                    </td>
                                    <td>
                                        <i class="bi bi-calendar-check"></i> 
                                        {{ item.total_sessions }} session(s)
                                    </td>
                                    <td style="min-width: 150px;">
                                        <div class="progress" style="height: 25px;">
                                            <div class="progress-bar bg-success" 
                                                 style="width: {{ item.moyenne_progression }}%">
                                                {{ item.moyenne_progression }}%
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <a href="{{ path('front_session_start', {'idEx': item.exercice.idEx}) }}" 
                                           class="btn btn-sm btn-outline-success">
                                            <i class="bi bi-play-fill"></i> Refaire
                                        </a>
                                    </td>
                                </tr>
                                {% endif %}
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const ctx = document.getElementById('evolutionChart').getContext('2d');
    const evolutionData = {{ evolution|json_encode|raw }};
    
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: evolutionData.labels,
            datasets: [{
                label: 'Exercices réalisés',
                data: evolutionData.data,
                backgroundColor: 'rgba(54, 162, 235, 0.2)',
                borderColor: 'rgba(54, 162, 235, 1)',
                borderWidth: 2,
                tension: 0.3,
                fill: true,
                pointBackgroundColor: 'rgba(54, 162, 235, 1)',
                pointBorderColor: '#fff',
                pointBorderWidth: 2,
                pointRadius: 4,
                pointHoverRadius: 6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    position: 'top',
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            return `Exercices: ${context.parsed.y}`;
                        }
                    }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        stepSize: 1,
                        precision: 0
                    },
                    title: {
                        display: true,
                        text: 'Nombre d\'exercices'
                    }
                },
                x: {
                    title: {
                        display: true,
                        text: 'Date'
                    }
                }
            }
        }
    });
});
</script>
{% endblock %}