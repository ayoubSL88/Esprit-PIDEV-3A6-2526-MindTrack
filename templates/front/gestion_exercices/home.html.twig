{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}Espace Exercices{% endblock %}

{% block content %}
    <div class="page-stack">
        <section class="hero-card">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
                <div class="space-y-3">
                    <p class="hero-kicker">Exercices</p>
                    <h1 class="hero-title text-ink">Espace exercices</h1>
                    <p class="hero-copy">
                        Un espace plus propre pour explorer les exercices, suivre la progression et lancer une session sans casser le design global du site.
                    </p>
                    <div class="hero-badge-row">
                        <span class="cta-highlight">Bien-etre</span>
                        <span class="hero-note">{{ recent_exercices|length }} exercices recents</span>
                        {% if stats %}
                            <span class="hero-note">{{ stats.total|default(0) }} sessions terminees</span>
                        {% endif %}
                    </div>
                </div>

                <div class="button-row">
                    <a href="{{ path('front_gestion_exercices_index') }}" class="btn-primary">Voir les exercices</a>
                    <a href="{{ path('front_home') }}" class="btn-secondary">Retour</a>
                </div>
            </div>
        </section>

        <section class="panel-section page-stack">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
                <div>
                    <p class="feature-label">Suggestions</p>
                    <h2 class="panel-title">Suggestions IA personnalisees</h2>
                </div>
                <p class="panel-copy">Base sur votre humeur et votre historique d'exercices.</p>
            </div>

            <div class="grid gap-4 lg:grid-cols-2">
                <article class="feature-card">
                    <p class="feature-label">Pour vous</p>
                    <p class="feature-title">Recommandation personnalisee</p>
                    <p class="feature-copy">Un exercice suggere a partir de votre historique et de votre progression recente.</p>
                    <div class="button-row mt-4">
                        <a href="{{ path('front_suggestion_for_you') }}" class="btn-primary">Voir la recommandation</a>
                    </div>
                </article>

                <article class="feature-card">
                    <p class="feature-label">Humeur du jour</p>
                    <p class="feature-title">Choisir selon votre etat</p>
                    <p class="feature-copy">Selectionnez un niveau d'humeur pour obtenir un exercice adapte.</p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        {% for mood in 1..10 %}
                            {% set moodClass = mood <= 3 ? 'bg-danger-soft text-danger border-danger-border' : (mood <= 6 ? 'bg-accent-soft text-amber-700 border-accent/50' : 'bg-success-soft text-success border-success-border') %}
                            <a
                                href="{{ path('front_suggestion_by_mood', {'mood': mood}) }}"
                                class="inline-flex h-10 w-10 items-center justify-center rounded-full border text-sm font-semibold transition hover:-translate-y-0.5 {{ moodClass }}"
                                title="Humeur: {{ mood }}/10"
                            >
                                {{ mood }}
                            </a>
                        {% endfor %}
                    </div>
                    <p class="mt-3 text-xs uppercase tracking-[0.16em] text-muted">1-3 bas, 4-6 stable, 7-10 eleve</p>
                </article>
            </div>
        </section>

        <section class="panel-section page-stack">
            <div>
                <p class="feature-label">Dashboard</p>
                <h2 class="panel-title">Votre tableau de bord</h2>
            </div>

            <div class="feature-grid">
                <article class="feature-card">
                    <p class="feature-label">Exercices termines</p>
                    <p class="feature-title">{{ stats.total|default(0) }}</p>
                    <p class="feature-copy">Nombre total de sessions terminees.</p>
                </article>
                <article class="feature-card">
                    <p class="feature-label">Temps investi</p>
                    <p class="feature-title">{{ stats.temps|default(0) }} min</p>
                    <p class="feature-copy">Temps total passe dans vos exercices.</p>
                </article>
                <article class="feature-card">
                    <p class="feature-label">Progression moyenne</p>
                    <p class="feature-title">{{ stats.moyenne|default(0) }}%</p>
                    <p class="feature-copy">Progression moyenne sur vos sessions completes.</p>
                </article>
                <article class="feature-card">
                    <p class="feature-label">Catalogue actif</p>
                    <p class="feature-title">{{ recent_exercices|length }}</p>
                    <p class="feature-copy">Derniers exercices ajoutes dans la plateforme.</p>
                </article>
            </div>
        </section>

        <section class="panel-section page-stack">
            <div>
                <p class="feature-label">Acces rapide</p>
                <h2 class="panel-title">Ou voulez-vous aller ?</h2>
            </div>

            <div class="feature-grid">
                <article class="feature-card">
                    <p class="feature-label">Catalogue</p>
                    <p class="feature-title">Tous les exercices</p>
                    <p class="feature-copy">Explorez l'ensemble des exercices disponibles.</p>
                    <div class="button-row mt-4">
                        <a href="{{ path('front_gestion_exercices_index') }}" class="btn-secondary">Ouvrir</a>
                    </div>
                </article>
                <article class="feature-card">
                    <p class="feature-label">Historique</p>
                    <p class="feature-title">Mes seances</p>
                    <p class="feature-copy">Consultez vos sessions passees et vos resultats.</p>
                    <div class="button-row mt-4">
                        <a href="{{ path('front_historique_index') }}" class="btn-secondary">Voir l'historique</a>
                    </div>
                </article>
                <article class="feature-card">
                    <p class="feature-label">Progression</p>
                    <p class="feature-title">Mon evolution</p>
                    <p class="feature-copy">Suivez votre progression globale par exercice.</p>
                    <div class="button-row mt-4">
                        <a href="{{ path('front_progression_index') }}" class="btn-secondary">Voir la progression</a>
                    </div>
                </article>
            </div>
        </section>

        {% if stats.recent_sessions is defined and stats.recent_sessions|length > 0 %}
            <section class="panel-section page-stack">
                <div>
                    <p class="feature-label">Activite recente</p>
                    <h2 class="panel-title">Dernieres seances</h2>
                </div>

                <div class="table-shell">
                    <div class="table-wrap">
                        <table class="table">
                            <thead class="table-head">
                                <tr>
                                    <th class="table-th">Exercice</th>
                                    <th class="table-th">Date</th>
                                    <th class="table-th">Progression</th>
                                    <th class="table-th">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for session in stats.recent_sessions %}
                                    <tr>
                                        <td class="table-td">{{ session.exercice.nom }}</td>
                                        <td class="table-td">{{ session.dateFin|date('d/m/Y H:i') }}</td>
                                        <td class="table-td">{{ session.progress }}%</td>
                                        <td class="table-td">
                                            <a href="{{ path('front_historique_show', {'idSession': session.idSession}) }}" class="btn-secondary">Detail</a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        {% endif %}

        <section class="panel-section page-stack">
            <div>
                <p class="feature-label">Nouveautes</p>
                <h2 class="panel-title">Decouvrez nos exercices</h2>
            </div>

            <div class="feature-grid">
                {% for exercice in recent_exercices %}
                    <article class="feature-card">
                        <p class="feature-label">{{ exercice.type }}</p>
                        <p class="feature-title">{{ exercice.nom }}</p>
                        <p class="feature-copy">{{ exercice.description|slice(0, 120) }}{% if exercice.description|length > 120 %}...{% endif %}</p>
                        <div class="button-row mt-4">
                            <a href="{{ path('front_gestion_exercices_show', {'idEx': exercice.idEx}) }}" class="btn-secondary">Voir l'exercice</a>
                        </div>
                    </article>
                {% endfor %}
            </div>
        </section>
    </div>
{% endblock %}
