{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}Mon historique d'exercices{% endblock %}

{% block content %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="bi bi-clock-history text-primary"></i> 
            Mon historique
        </h1>
        <a href="{{ path('front_gestion_exercices_index') }}" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left"></i> Retour aux exercices
        </a>
    </div>

    <!-- Statistiques rapides -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white shadow-sm">
                <div class="card-body text-center">
                    <i class="bi bi-check-circle fs-1"></i>
                    <h3 class="mt-2 mb-0">{{ stats.total }}</h3>
                    <p class="mb-0">Exercices terminés</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white shadow-sm">
                <div class="card-body text-center">
                    <i class="bi bi-stopwatch fs-1"></i>
                    <h3 class="mt-2 mb-0">{{ (stats.temps_total / 60)|round }} min</h3>
                    <p class="mb-0">Temps total passé</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-white shadow-sm">
                <div class="card-body text-center">
                    <i class="bi bi-graph-up fs-1"></i>
                    <h3 class="mt-2 mb-0">{{ stats.moyenne_progression|round }}%</h3>
                    <p class="mb-0">Progression moyenne</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Liste des sessions -->
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0">Mes séances</h5>
        </div>
        <div class="card-body p-0">
            {% if sessions is empty %}
                <div class="text-center py-5">
                    <i class="bi bi-emoji-frown fs-1 text-muted"></i>
                    <h4 class="mt-3">Aucune session terminée</h4>
                    <p>Commencez un exercice pour voir votre historique ici.</p>
                    <a href="{{ path('front_gestion_exercices_index') }}" class="btn btn-primary">
                        <i class="bi bi-play-fill"></i> Découvrir les exercices
                    </a>
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Exercice</th>
                                <th>Date</th>
                                <th>Durée</th>
                                <th>Progression</th>
                                <th>Résultat</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for session in sessions %}
                            <tr>
                                <td>
                                    <strong>{{ session.exercice.nom }}</strong><br>
                                    <small class="text-muted">{{ session.exercice.type }}</small>
                                </td>
                                <td>{{ session.dateFin|date('d/m/Y H:i') }}</td>
                                <td>
                                    {% if session.dureeReelle %}
                                        {{ (session.dureeReelle / 60)|round }} min
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="progress" style="height: 8px; width: 100px;">
                                        <div class="progress-bar bg-{{ session.progress == 100 ? 'success' : 'primary' }}" 
                                             style="width: {{ session.progress }}%"></div>
                                    </div>
                                    <small>{{ session.progress }}%</small>
                                </td>
                                <td>
                                    {% if session.resultat %}
                                        <span class="badge bg-success">{{ session.resultat }}</span>
                                    {% else %}
                                        <span class="badge bg-secondary">Terminé</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <a href="{{ path('front_historique_show', {'idSession': session.idSession}) }}" 
                                       class="btn btn-sm btn-outline-info">
                                        <i class="bi bi-eye"></i> Détail
                                    </a>
                                </td>
                             </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}