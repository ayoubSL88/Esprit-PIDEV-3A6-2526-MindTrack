{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}Mes Exercices{% endblock %}

{% block content %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Mes Exercices</h1>
        <div class="dropdown">
            <button class="btn btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                <i class="bi bi-funnel"></i> Filtrer
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="{{ path('front_gestion_exercices_index') }}">Tous</a></li>
                <li><a class="dropdown-item" href="{{ path('front_gestion_exercices_index', {'difficulte': 'FACILE'}) }}">Facile</a></li>
                <li><a class="dropdown-item" href="{{ path('front_gestion_exercices_index', {'difficulte': 'MOYEN'}) }}">Moyen</a></li>
                <li><a class="dropdown-item" href="{{ path('front_gestion_exercices_index', {'difficulte': 'DIFFICILE'}) }}">Difficile</a></li>
            </ul>
        </div>
    </div>

    {# Barre de recherche #}
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-9">
                    <input type="text" name="search" value="{{ search }}" class="form-control form-control-lg" 
                           placeholder="Rechercher un exercice par nom ou type...">
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="bi bi-search"></i> Rechercher
                    </button>
                </div>
            </form>
        </div>
    </div>

    {# Grille des exercices #}
    {% if exercices is empty %}
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-emoji-frown fs-1"></i>
            <h4 class="mt-3">Aucun exercice trouvé</h4>
            <p>Essayez de modifier vos critères de recherche.</p>
        </div>
    {% else %}
        <div class="row">
            {% for exercice in exercices %}
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm hover-shadow transition">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title text-primary">{{ exercice.nom }}</h5>
                                <span class="badge 
                                    {% if exercice.difficulte == 'FACILE' %}bg-success
                                    {% elseif exercice.difficulte == 'MOYEN' %}bg-warning text-dark
                                    {% else %}bg-danger
                                    {% endif %} px-3 py-2">
                                    {{ exercice.difficulte|capitalize }}
                                </span>
                            </div>
                            <h6 class="card-subtitle mb-2 text-muted">
                                <i class="bi bi-tag"></i> {{ exercice.type }}
                            </h6>
                            <p class="card-text">{{ exercice.description|slice(0, 100) }}{% if exercice.description|length > 100 %}...{% endif %}</p>
                            <div class="mb-3">
                                <small class="text-muted">
                                    <i class="bi bi-clock"></i> {{ exercice.duree }} minutes
                                </small>
                                <br>
                                <small class="text-muted">
                                    <i class="bi bi-calendar"></i> Créé le {{ exercice.dateCreation|date('d/m/Y') }}
                                </small>
                            </div>
                            <div class="d-grid gap-2">
                                <a href="{{ path('front_gestion_exercices_show', {'idEx': exercice.idEx}) }}" 
                                   class="btn btn-outline-primary">
                                    <i class="bi bi-eye"></i> Voir l'exercice
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .hover-shadow:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
            transition: all 0.3s ease;
        }
        .transition {
            transition: all 0.3s ease;
        }
    </style>
{% endblock %}