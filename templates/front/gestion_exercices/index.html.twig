{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}Mes Exercices{% endblock %}

{% block content %}
    <div class="page-stack">
        <section class="panel-section page-stack">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
                <div class="space-y-3">
                    <p class="feature-label">Catalogue</p>
                    <h1 class="page-title">Mes exercices</h1>
                    <p class="page-copy">Explorez les exercices, filtrez par difficulte et ouvrez rapidement une fiche detaillee.</p>
                </div>
                <div class="button-row">
                    <a href="{{ path('front_gestion_exercices_home') }}" class="btn-secondary">Retour a l'espace exercices</a>
                </div>
            </div>

            <form method="get" class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_220px_220px_auto]">
                <div class="field">
                    <label for="exercise-search" class="field-label">Recherche</label>
                    <input
                        id="exercise-search"
                        type="text"
                        name="search"
                        value="{{ search }}"
                        class="field-input"
                        placeholder="Rechercher un exercice par nom ou type"
                    >
                </div>

                <div class="field">
                    <label for="exercise-difficulty" class="field-label">Difficulte</label>
                    <select id="exercise-difficulty" name="difficulte" class="field-select">
                        <option value="">Toutes</option>
                        <option value="FACILE" {{ difficulte == 'FACILE' ? 'selected' : '' }}>Facile</option>
                        <option value="MOYEN" {{ difficulte == 'MOYEN' ? 'selected' : '' }}>Moyen</option>
                        <option value="DIFFICILE" {{ difficulte == 'DIFFICILE' ? 'selected' : '' }}>Difficile</option>
                    </select>
                </div>

                <div class="field">
                    <label for="exercise-sort" class="field-label">Tri</label>
                    <select id="exercise-sort" name="sort" class="field-select">
                        <option value="nom" {{ sort == 'nom' ? 'selected' : '' }}>Nom</option>
                        <option value="difficulte" {{ sort == 'difficulte' ? 'selected' : '' }}>Difficulte</option>
                        <option value="date_creation" {{ sort == 'date_creation' ? 'selected' : '' }}>Date</option>
                    </select>
                </div>

                <div class="button-row lg:self-end">
                    <button type="submit" class="btn-primary">Filtrer</button>
                </div>
            </form>
        </section>

        {% if exercices is empty %}
            <section class="panel-section">
                <p class="feature-label">Aucun resultat</p>
                <h2 class="panel-title">Aucun exercice trouve</h2>
                <p class="panel-copy">Essayez de modifier vos criteres de recherche ou de retirer un filtre.</p>
            </section>
        {% else %}
            <section class="feature-grid">
                {% for exercice in exercices %}
                    {% set difficultyClasses = exercice.difficulte == 'FACILE'
                        ? 'bg-success-soft text-success border-success-border'
                        : (exercice.difficulte == 'MOYEN'
                            ? 'bg-accent-soft text-amber-700 border-accent/50'
                            : 'bg-danger-soft text-danger border-danger-border')
                    %}
                    <article class="feature-card flex h-full flex-col">
                        <div class="flex items-start justify-between gap-3">
                            <div class="space-y-2">
                                <p class="feature-label">{{ exercice.type }}</p>
                                <h2 class="text-xl font-semibold text-ink">{{ exercice.nom }}</h2>
                            </div>
                            <span class="inline-flex rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] {{ difficultyClasses }}">
                                {{ exercice.difficulte }}
                            </span>
                        </div>

                        <p class="feature-copy mt-4 flex-1">
                            {{ exercice.description|slice(0, 120) }}{% if exercice.description|length > 120 %}...{% endif %}
                        </p>

                        <div class="mt-4 grid gap-2 text-sm text-muted">
                            <p>{{ exercice.duree }} minutes</p>
                            <p>Cree le {{ exercice.dateCreation|date('d/m/Y') }}</p>
                        </div>

                        <div class="button-row mt-5">
                            <a href="{{ path('front_gestion_exercices_show', {'idEx': exercice.idEx}) }}" class="btn-secondary">Voir l'exercice</a>
                        </div>
                    </article>
                {% endfor %}
            </section>
        {% endif %}
    </div>
{% endblock %}
