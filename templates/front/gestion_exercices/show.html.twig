{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}{{ exercice.nom }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* STYLE MODERNE */
        .breadcrumb {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 24px;
            font-size: 0.85rem;
        }
        
        .breadcrumb a {
            color: #6366f1;
            text-decoration: none;
        }
        
        .breadcrumb a:hover {
            text-decoration: underline;
        }
        
        .breadcrumb .separator {
            color: #cbd5e1;
        }
        
        .breadcrumb .current {
            color: #64748b;
        }
        
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            flex-wrap: wrap;
            gap: 16px;
        }
        
        .page-header h1 {
            font-size: 1.8rem;
            font-weight: 700;
            background: linear-gradient(135deg, #1e293b, #475569);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 0;
        }
        
        .show-grid {
            display: grid;
            grid-template-columns: 1fr 0.7fr;
            gap: 28px;
        }
        
        /* CARTE PRINCIPALE */
        .main-card {
            background: white;
            border-radius: 28px;
            overflow: hidden;
            box-shadow: 0 8px 30px rgba(0,0,0,0.05);
            border: 1px solid #f1f5f9;
        }
        
        .main-card-body {
            padding: 32px;
        }
        
        .badge-group {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 24px;
        }
        
        .badge-show {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 600;
        }
        
        .badge-type {
            background: #eef2ff;
            color: #4f46e5;
        }
        
        .badge-facile {
            background: #d1fae5;
            color: #065f46;
        }
        
        .badge-moyen {
            background: #fed7aa;
            color: #9a3412;
        }
        
        .badge-difficile {
            background: #fee2e2;
            color: #dc2626;
        }
        
        .badge-duree {
            background: #f1f5f9;
            color: #475569;
        }
        
        .section-title {
            font-size: 1rem;
            font-weight: 600;
            color: #1e293b;
            margin: 24px 0 12px 0;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .section-title:first-of-type {
            margin-top: 0;
        }
        
        .description-content {
            color: #475569;
            line-height: 1.7;
        }
        
        .demarche-content {
            background: linear-gradient(135deg, #f8fafc, #f1f5f9);
            border-radius: 20px;
            padding: 24px;
            line-height: 1.8;
            color: #334155;
        }
        
        /* CARTE INFOS LATÉRALE */
        .info-card {
            background: white;
            border-radius: 28px;
            overflow: hidden;
            box-shadow: 0 8px 30px rgba(0,0,0,0.05);
            border: 1px solid #f1f5f9;
            margin-bottom: 24px;
        }
        
        .info-header {
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            padding: 20px 24px;
            color: white;
        }
        
        .info-header h5 {
            margin: 0;
            font-size: 1rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .info-body {
            padding: 24px;
        }
        
        .info-list {
            list-style: none;
            padding: 0;
            margin: 0 0 24px 0;
        }
        
        .info-list li {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 0;
            border-bottom: 1px solid #f1f5f9;
        }
        
        .info-list li:last-child {
            border-bottom: none;
        }
        
        .info-list .info-icon {
            font-size: 1.2rem;
        }
        
        .info-list .info-text {
            flex: 1;
        }
        
        .info-list .info-label {
            font-size: 0.7rem;
            color: #94a3b8;
        }
        
        .info-list .info-value {
            font-weight: 600;
            color: #1e293b;
        }
        
        .btn-start {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
            background: linear-gradient(135deg, #10b981, #34d399);
            color: white;
            padding: 14px 24px;
            border-radius: 40px;
            text-decoration: none;
            font-weight: 600;
            font-size: 1rem;
            transition: all 0.2s;
            border: none;
            cursor: pointer;
        }
        
        .btn-start:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(16,185,129,0.3);
        }
        
        .btn-print {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            background: #f1f5f9;
            color: #475569;
            padding: 12px 20px;
            border-radius: 40px;
            text-decoration: none;
            font-weight: 500;
            margin-top: 12px;
            transition: all 0.2s;
            border: none;
            cursor: pointer;
        }
        
        .btn-print:hover {
            background: #e2e8f0;
        }
        
        .tips-card {
            background: #fffbeb;
            border-radius: 20px;
            padding: 20px;
            border-left: 4px solid #f59e0b;
        }
        
        .tips-card h6 {
            color: #d97706;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .tips-card p {
            color: #78350f;
            font-size: 0.85rem;
            line-height: 1.5;
            margin: 0;
        }
        
        @media (max-width: 900px) {
            .show-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }
            .page-header {
                flex-direction: column;
                align-items: flex-start;
            }
            .main-card-body {
                padding: 24px;
            }
        }
        
        @media print {
            .btn-start, .btn-print, .info-card .btn-print, nav, footer {
                display: none !important;
            }
            .main-card, .info-card {
                box-shadow: none;
                border: 1px solid #ddd;
            }
        }
    </style>
{% endblock %}

{% block content %}
    <div style="max-width: 1200px; margin: 0 auto; padding: 20px;">
        <!-- FIL D'ARIANE -->
        <div class="breadcrumb">
            <a href="{{ path('front_gestion_exercices_home') }}">🏠 Espace exercices</a>
            <span class="separator">›</span>
            <a href="{{ path('front_gestion_exercices_index') }}">📚 Mes exercices</a>
            <span class="separator">›</span>
            <span class="current">{{ exercice.nom }}</span>
        </div>
        
        <!-- EN-TÊTE -->
        <section class="page-header">
            <div>
                <h1>✨ {{ exercice.nom }}</h1>
            </div>
            <a href="{{ path('front_gestion_exercices_index') }}" style="background: #f1f5f9; color: #475569; padding: 10px 20px; border-radius: 40px; text-decoration: none; font-weight: 500;">
                ← Retour à la liste
            </a>
        </section>

        <div class="show-grid">
            <!-- COLONNE GAUCHE : DESCRIPTION DÉTAILLÉE -->
            <div class="main-card">
                <div class="main-card-body">
                    <!-- BADGES -->
                    <div class="badge-group">
                        <span class="badge-show badge-type">❄️ {{ exercice.type }}</span>
                        <span class="badge-show 
                            {% if exercice.difficulte == 'FACILE' %}badge-facile
                            {% elseif exercice.difficulte == 'MOYEN' %}badge-moyen
                            {% else %}badge-difficile{% endif %}">
                            📊 {{ exercice.difficulte|capitalize }}
                        </span>
                        <span class="badge-show badge-duree">
                            ⏱️ {{ exercice.duree }} minutes
                        </span>
                    </div>
                    
                    <!-- DESCRIPTION -->
                    <div class="section-title">
                        <span>📝</span> Description
                    </div>
                    <div class="description-content">
                        {{ exercice.description|nl2br }}
                    </div>
                    
                    <!-- DÉMARCHE -->
                    <div class="section-title">
                        <span>📋</span> Démarche à suivre
                    </div>
                    <div class="demarche-content">
                        {{ exercice.demarche|nl2br }}
                    </div>
                </div>
            </div>

            <!-- COLONNE DROITE : INFORMATIONS -->
            <div>
                <!-- CARTE INFOS -->
                <div class="info-card">
                    <div class="info-header">
                        <h5>
                            <span>ℹ️</span> Informations
                        </h5>
                    </div>
                    <div class="info-body">
                        <ul class="info-list">
                            <li>
                                <span class="info-icon">⏱️</span>
                                <div class="info-text">
                                    <div class="info-label">Durée estimée</div>
                                    <div class="info-value">{{ exercice.duree }} minutes</div>
                                </div>
                            </li>
                            <li>
                                <span class="info-icon">📅</span>
                                <div class="info-text">
                                    <div class="info-label">Date de création</div>
                                    <div class="info-value">{{ exercice.dateCreation|date('d/m/Y à H:i') }}</div>
                                </div>
                            </li>
                            {% if exercice.dateModification %}
                            <li>
                                <span class="info-icon">✏️</span>
                                <div class="info-text">
                                    <div class="info-label">Dernière modification</div>
                                    <div class="info-value">{{ exercice.dateModification|date('d/m/Y à H:i') }}</div>
                                </div>
                            </li>
                            {% endif %}
                        </ul>
                        
                        <a href="{{ path('front_session_start', {'idEx': exercice.idEx}) }}" class="btn-start">
                            🚀 Commencer l'exercice
                        </a>
                        
                        <button class="btn-print" onclick="window.print()">
                            🖨️ Imprimer
                        </button>
                    </div>
                </div>
                
                <!-- CARTE CONSEILS -->
                <div class="tips-card">
                    <h6>
                        <span>💡</span> Conseils
                    </h6>
                    <p>
                        Prends ton temps, suis la démarche étape par étape, 
                        et n'hésite pas à prendre des notes pour suivre ta progression.
                        La régularité est la clé du succès ! 🌟
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}