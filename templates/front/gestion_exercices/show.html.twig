{% extends 'layouts/front_base.html.twig' %}

{% block page_title %}{{ exercice.nom }}{% endblock %}

{% block content %}
    <div class="page-stack">
        <section class="panel-section page-stack">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                <div class="space-y-3">
                    <a href="{{ path('front_gestion_exercices_index') }}" class="text-sm font-medium text-brand hover:underline">
                        Retour au catalogue
                    </a>
                    <div class="flex flex-wrap items-center gap-3">
                        <p class="feature-label">{{ exercice.type }}</p>
                        {% set difficultyClasses = exercice.difficulte == 'FACILE'
                            ? 'bg-success-soft text-success border-success-border'
                            : (exercice.difficulte == 'MOYEN'
                                ? 'bg-accent-soft text-amber-700 border-accent/50'
                                : 'bg-danger-soft text-danger border-danger-border')
                        %}
                        <span class="inline-flex rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] {{ difficultyClasses }}">
                            {{ exercice.difficulte }}
                        </span>
                    </div>
                    <h1 class="page-title">{{ exercice.nom }}</h1>
                    <p class="page-copy">{{ exercice.description }}</p>
                </div>

                <div class="button-row">
                    <a href="{{ path('front_session_start', {'idEx': exercice.idEx}) }}" class="btn-primary">Commencer l'exercice</a>
                    <button type="button" class="btn-secondary" onclick="window.print()">Imprimer</button>
                </div>
            </div>
        </section>

        <section class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_320px]">
            <article class="panel-section page-stack">
                <div>
                    <p class="feature-label">Description</p>
                    <h2 class="panel-title">Ce que vous allez faire</h2>
                </div>
                <div class="rounded-3xl border border-border bg-white/80 p-5 text-sm leading-7 text-ink">
                    {{ exercice.description|nl2br }}
                </div>

                <div>
                    <p class="feature-label">Demarche</p>
                    <h2 class="panel-title">Etapes conseillees</h2>
                </div>
                <div class="rounded-3xl border border-border bg-white/80 p-5 text-sm leading-7 text-ink">
                    {{ exercice.demarche|raw }}
                </div>
            </article>

            <aside class="page-stack">
                <section class="panel-section page-stack">
                    <div>
                        <p class="feature-label">Informations</p>
                        <h2 class="panel-title">Resume rapide</h2>
                    </div>
                    <div class="grid gap-3">
                        <div class="rounded-3xl border border-border bg-white/85 p-4">
                            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">Duree</p>
                            <p class="mt-2 text-lg font-semibold text-ink">{{ exercice.duree }} minutes</p>
                        </div>
                        <div class="rounded-3xl border border-border bg-white/85 p-4">
                            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">Date de creation</p>
                            <p class="mt-2 text-lg font-semibold text-ink">{{ exercice.dateCreation|date('d/m/Y H:i') }}</p>
                        </div>
                        {% if exercice.dateModification %}
                            <div class="rounded-3xl border border-border bg-white/85 p-4">
                                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">Derniere modification</p>
                                <p class="mt-2 text-lg font-semibold text-ink">{{ exercice.dateModification|date('d/m/Y H:i') }}</p>
                            </div>
                        {% endif %}
                    </div>
                </section>

                <section class="panel-section page-stack">
                    <div>
                        <p class="feature-label">Conseils</p>
                        <h2 class="panel-title">Avant de commencer</h2>
                    </div>
                    <p class="panel-copy">
                        Prenez votre temps, suivez la demarche et gardez une trace de ce qui vous aide vraiment pour mieux mesurer votre progression.
                    </p>
                </section>
            </aside>
        </section>
    </div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        @media print {
            .app-navbar,
            .btn-primary,
            .btn-secondary {
                display: none !important;
            }

            .page-card,
            .panel-section {
                border: none !important;
                box-shadow: none !important;
                background: #fff !important;
            }
        }
    </style>
{% endblock %}
