{% extends 'layouts/admin_base.html.twig' %}

{% block page_title %}Gestion des exercices{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Exercices</h1>
    <a href="{{ path('admin_gestion_exercices_new') }}" class="btn btn-primary">+ Nouvel exercice</a>
</div>

{# Formulaire de recherche #}
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-5">
                <input type="text" name="search" value="{{ app.request.query.get('search') }}" 
                       class="form-control" placeholder="Rechercher par nom ou type...">
            </div>
            <div class="col-md-4">
                <select name="difficulte" class="form-select">
                    <option value="">Niveau de difficulté</option>
                    <option value="FACILE" {% if difficulte == 'FACILE' %}selected{% endif %}>Facile</option>
                    <option value="MOYEN" {% if difficulte == 'MOYEN' %}selected{% endif %}>Moyen</option>
                    <option value="DIFFICILE" {% if difficulte == 'DIFFICILE' %}selected{% endif %}>Difficile</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-secondary">Filtrer</button>
                <a href="{{ path('admin_gestion_exercices_index') }}" class="btn btn-link">Réinitialiser</a>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Type</th>
                <th>Durée</th>
                <th>Difficulté</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for exercice in exercices %}
            <tr>
                <td>{{ exercice.nom }}</td>
                <td>{{ exercice.type }}</td>
                <td>{{ exercice.duree }} min</td>
                <td>
                    <span class="badge bg-{{ exercice.difficulte == 'FACILE' ? 'success' : (exercice.difficulte == 'MOYEN' ? 'warning' : 'danger') }}">
                        {{ exercice.difficulte }}
                    </span>
                </td>
                <td>
                    <a href="{{ path('admin_gestion_exercices_show', {'idEx': exercice.idEx}) }}" class="btn btn-sm btn-info">Voir</a>
                    <a href="{{ path('admin_gestion_exercices_edit', {'idEx': exercice.idEx}) }}" class="btn btn-sm btn-warning">Modifier</a>
                    <form method="post" action="{{ path('admin_gestion_exercices_delete', {'idEx': exercice.idEx}) }}" style="display:inline-block">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ exercice.idEx) }}">
                        <button class="btn btn-sm btn-danger" onclick="return confirm('Supprimer ?')">Supprimer</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6" class="text-center">Aucun exercice trouvé</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}