{% extends 'layouts/admin_base.html.twig' %}

{% block page_title %}Gestion Humeur{% endblock %}

{% block content %}
    <div class="page-stack">
        {{ component('PageHeader', {
            eyebrow: 'Administration',
            title: 'Gestion Humeur',
            copy: 'View and delete mood entries from the admin area.'
        }) }}

        <div class="button-row">
            <a class="btn-secondary" href="{{ path('admin_gestion_humeur_journal_index') }}">View journals</a>
        </div>

        {{ component('FlashStack') }}

        {% if humeurs is empty %}
            <p class="text-sm text-muted">No humeur entries found yet.</p>
        {% else %}
            <div class="panel-section space-y-4">
                <div class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_220px] lg:items-end">
                    <div class="field">
                        <label class="field-label" for="admin-humeur-search">Search</label>
                        <input
                            id="admin-humeur-search"
                            class="field-input"
                            type="search"
                            placeholder="Search by ID or humeur type..."
                            data-search-target="admin-humeur-table"
                            data-empty-target="admin-humeur-empty"
                        >
                        <p class="text-xs text-muted">Search dynamically by humeur ID or humeur type.</p>
                    </div>
                    <div class="field">
                        <label class="field-label" for="admin-humeur-sort">Sort by date</label>
                        <select id="admin-humeur-sort" class="field-select">
                            <option value="latest">Latest</option>
                            <option value="oldest">Oldest</option>
                        </select>
                    </div>
                </div>

                <div class="grid gap-4 lg:grid-cols-[220px_minmax(0,1fr)] lg:items-end">
                    <div class="field">
                        <label class="field-label" for="admin-humeur-filter-type">Filter by</label>
                        <select id="admin-humeur-filter-type" class="field-select">
                            <option value="intensity">Intensity</option>
                            <option value="date">Date</option>
                        </select>
                    </div>
                    <div class="field">
                        <label class="field-label" for="admin-humeur-filter-value">Filter value</label>
                        <input id="admin-humeur-filter-value" class="field-input" type="number" min="1" max="10" placeholder="Filter by intensity...">
                    </div>
                </div>
            </div>

            <div class="table-shell">
                <div class="table-wrap">
                    <table class="table">
                        <thead class="table-head">
                            <tr>
                                <th class="table-th">ID</th>
                                <th class="table-th">Date</th>
                                <th class="table-th">Type humeur</th>
                                <th class="table-th">Intensite</th>
                                <th class="table-th">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="admin-humeur-table">
                            {% for humeur in humeurs %}
                                <tr data-search-value="{{ humeur.idH }} {{ humeur.typeHumeur|lower }}" data-date-value="{{ humeur.date|date('Y-m-d') }}" data-intensity-value="{{ humeur.intensite }}">
                                    <td class="table-td">{{ humeur.idH }}</td>
                                    <td class="table-td">{{ humeur.date|date('Y-m-d') }}</td>
                                    <td class="table-td">{{ humeur.typeHumeur }}</td>
                                    <td class="table-td">{{ humeur.intensite }}/10</td>
                                    <td class="table-td">
                                        <div class="button-row">
                                            <a class="btn-secondary px-4 py-2" href="{{ path('admin_gestion_humeur_show', {idH: humeur.idH}) }}">View</a>
                                            {% include 'admin/gestion_humeur/humeur/_delete_form.html.twig' with {
                                                delete_path: path('admin_gestion_humeur_delete', {idH: humeur.idH}),
                                                csrf_token: csrf_token('delete_humeur_' ~ humeur.idH),
                                                button_label: 'Delete'
                                            } only %}
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <p id="admin-humeur-empty" class="mt-4 text-sm text-muted hidden">No humeur matches your search.</p>
        {% endif %}
    </div>

    <script>
        (() => {
            const input = document.getElementById('admin-humeur-search');
            const sort = document.getElementById('admin-humeur-sort');
            const filterType = document.getElementById('admin-humeur-filter-type');
            const filterValue = document.getElementById('admin-humeur-filter-value');
            if (!input || !sort || !filterType || !filterValue) {
                return;
            }

            const tableBody = document.getElementById(input.dataset.searchTarget);
            const emptyState = document.getElementById(input.dataset.emptyTarget);
            const rows = Array.from(tableBody.querySelectorAll('tr'));

            const applyFilters = () => {
                const term = input.value.trim().toLowerCase();
                const direction = sort.value;
                const mode = filterType.value;
                const filterTerm = filterValue.value.trim().toLowerCase();
                const sortedRows = [...rows].sort((a, b) => {
                    const left = new Date(a.dataset.dateValue);
                    const right = new Date(b.dataset.dateValue);
                    return direction === 'oldest' ? left - right : right - left;
                });

                sortedRows.forEach((row) => tableBody.appendChild(row));

                let visibleCount = 0;

                sortedRows.forEach((row) => {
                    const searchable = row.dataset.searchValue || '';
                    const matchesSearch = term === '' || searchable.includes(term);
                    const filterSource = mode === 'date' ? (row.dataset.dateValue || '') : (row.dataset.intensityValue || '');
                    const matchesFilter = filterTerm === '' || filterSource.includes(filterTerm);
                    const visible = matchesSearch && matchesFilter;
                    row.style.display = visible ? '' : 'none';
                    if (visible) {
                        visibleCount += 1;
                    }
                });

                emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
            };

            input.addEventListener('input', applyFilters);
            sort.addEventListener('change', applyFilters);
            filterType.addEventListener('change', () => {
                filterValue.value = '';
                filterValue.type = filterType.value === 'date' ? 'date' : 'number';
                filterValue.min = filterType.value === 'date' ? '' : '1';
                filterValue.max = filterType.value === 'date' ? '' : '10';
                filterValue.placeholder = filterType.value === 'date' ? 'Filter by date...' : 'Filter by intensity...';
                applyFilters();
            });
            filterValue.addEventListener('input', applyFilters);
            applyFilters();
        })();
    </script>
{% endblock %}
