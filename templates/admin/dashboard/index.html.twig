{% extends 'layouts/admin_base.html.twig' %}

{% block page_title %}Dashboard Administrateur{% endblock %}

{% block content %}
    <section class="space-y-6">
        <div class="rounded-[2rem] border border-border bg-white/90 p-6 shadow-soft sm:p-8">
            <div class="grid gap-6 xl:grid-cols-[1.35fr_0.95fr]">
                <div class="space-y-4">
                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-brand">Backoffice</p>
                        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-ink sm:text-4xl">Admin dashboard</h1>
                        <p class="mt-3 max-w-3xl text-sm leading-7 text-muted sm:text-base">
                            This stays inside EasyAdmin and turns the landing page into an operational overview instead of a CRUD redirect.
                            Use it to spot engagement gaps, security issues, and the modules that need action first.
                        </p>
                    </div>

                    <div class="grid gap-3 md:grid-cols-2 2xl:grid-cols-4">
                        <article class="rounded-3xl border border-border bg-panel/80 p-4 shadow-sm">
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand">Users</p>
                            <p class="mt-3 text-3xl font-semibold tracking-tight text-ink">{{ users_count }}</p>
                            <p class="mt-2 text-sm leading-6 text-muted">{{ admin_users_count }} admins, {{ standard_users_count }} members.</p>
                        </article>
                        <article class="rounded-3xl border border-border bg-panel/80 p-4 shadow-sm">
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand">Session completion</p>
                            <p class="mt-3 text-3xl font-semibold tracking-tight text-ink">{{ completion_rate }}%</p>
                            <p class="mt-2 text-sm leading-6 text-muted">{{ completed_sessions_count }} of {{ sessions_count }} sessions completed.</p>
                        </article>
                        <article class="rounded-3xl border border-border bg-panel/80 p-4 shadow-sm">
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand">Habit completion</p>
                            <p class="mt-3 text-3xl font-semibold tracking-tight text-ink">{{ habit_completion_rate }}%</p>
                            <p class="mt-2 text-sm leading-6 text-muted">{{ completed_habit_tracking_count }} completed habit check-ins.</p>
                        </article>
                        <article class="rounded-3xl border border-border bg-panel/80 p-4 shadow-sm">
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand">Security adoption</p>
                            <p class="mt-3 text-3xl font-semibold tracking-tight text-ink">
                                {{ users_count > 0 ? ((protected_users_count / users_count) * 100)|round(1) : 0 }}%
                            </p>
                            <p class="mt-2 text-sm leading-6 text-muted">{{ users_needing_security_review }} users still need stronger sign-in.</p>
                        </article>
                    </div>
                </div>

                <aside class="rounded-[1.75rem] border border-border bg-panel/80 p-5 shadow-soft">
                    <div class="flex items-start justify-between gap-3">
                        <div>
                            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand">Priority actions</p>
                            <h2 class="mt-2 text-xl font-semibold text-ink">Quick admin shortcuts</h2>
                        </div>
                        <span class="rounded-full bg-accent-soft px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-ink">Focus</span>
                    </div>

                    <div class="mt-5 space-y-3">
                        {% for link in quick_links %}
                            <a href="{{ link.url }}" class="block rounded-3xl border border-border bg-white/90 p-4 no-underline transition hover:-translate-y-0.5 hover:border-brand/60 hover:shadow-soft">
                                <p class="text-sm font-semibold text-ink">{{ link.label }}</p>
                                <p class="mt-2 text-sm leading-6 text-muted">{{ link.copy }}</p>
                            </a>
                        {% endfor %}
                    </div>
                </aside>
            </div>
        </div>

        <div class="grid gap-6 xl:grid-cols-[1.2fr_0.8fr]">
            <section class="rounded-[2rem] border border-border bg-white/90 p-6 shadow-soft">
                <div class="flex flex-col gap-2 border-b border-border/80 pb-4 sm:flex-row sm:items-end sm:justify-between">
                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand">Signals</p>
                        <h2 class="mt-2 text-xl font-semibold text-ink">Platform insights</h2>
                    </div>
                    <p class="text-sm text-muted">Small panels that answer what needs attention next.</p>
                </div>

                <div class="mt-5 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                    <article class="rounded-3xl border border-accent/50 bg-accent-soft/50 p-4 shadow-sm">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Security review</p>
                        <p class="mt-3 text-3xl font-semibold tracking-tight text-ink">{{ users_needing_security_review }}</p>
                        <p class="mt-2 text-sm leading-6 text-muted">{{ totp_enabled_count }} use TOTP, {{ face_enabled_count }} use face authentication.</p>
                    </article>
                    <article class="rounded-3xl border border-accent/50 bg-accent-soft/50 p-4 shadow-sm">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Exercise catalog gaps</p>
                        <p class="mt-3 text-3xl font-semibold tracking-tight text-ink">{{ unused_exercises_count }}</p>
                        <p class="mt-2 text-sm leading-6 text-muted">Exercises with no recorded sessions yet.</p>
                    </article>
                    <article class="rounded-3xl border border-border bg-panel/70 p-4 shadow-sm">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Habits tracked</p>
                        <p class="mt-3 text-3xl font-semibold tracking-tight text-ink">{{ habit_count }}</p>
                        <p class="mt-2 text-sm leading-6 text-muted">{{ habit_tracking_count }} check-ins recorded so far.</p>
                    </article>
                    <article class="rounded-3xl border border-border bg-panel/70 p-4 shadow-sm">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Mood coverage</p>
                        <p class="mt-3 text-3xl font-semibold tracking-tight text-ink">{{ mood_entries_count }}</p>
                        <p class="mt-2 text-sm leading-6 text-muted">Total mood entries available for wellbeing analysis.</p>
                    </article>
                    <article class="rounded-3xl border border-border bg-panel/70 p-4 shadow-sm">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Goals in flight</p>
                        <p class="mt-3 text-3xl font-semibold tracking-tight text-ink">{{ goal_count }}</p>
                        <p class="mt-2 text-sm leading-6 text-muted">Active planning inventory across the platform.</p>
                    </article>
                    <article class="rounded-3xl border border-success-border bg-success-soft/60 p-4 shadow-sm">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Exercise catalog</p>
                        <p class="mt-3 text-3xl font-semibold tracking-tight text-ink">{{ exercices_count }}</p>
                        <p class="mt-2 text-sm leading-6 text-muted">Total exercises currently available to users.</p>
                    </article>
                </div>

                <div class="mt-6 rounded-[1.75rem] border border-border bg-panel/70 p-5">
                    <h3 class="text-lg font-semibold text-ink">Weekly snapshot</h3>
                    <div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
                        <div class="rounded-3xl border border-border bg-white/85 p-4">
                            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Weekly activity</p>
                            <p class="mt-2 text-2xl font-semibold tracking-tight text-ink">{{ sessions_started_this_week }}</p>
                            <p class="mt-2 text-sm leading-6 text-muted">Sessions started in the last 7 days.</p>
                        </div>
                        <div class="rounded-3xl border border-border bg-white/85 p-4">
                            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Average progress</p>
                            <p class="mt-2 text-2xl font-semibold tracking-tight text-ink">{{ avg_progress }}%</p>
                            <p class="mt-2 text-sm leading-6 text-muted">Across the 200 most recent sessions.</p>
                        </div>
                        <div class="rounded-3xl border border-border bg-white/85 p-4">
                            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Mood check-ins</p>
                            <p class="mt-2 text-2xl font-semibold tracking-tight text-ink">{{ mood_entries_this_week }}</p>
                            <p class="mt-2 text-sm leading-6 text-muted">Mood entries recorded this week.</p>
                        </div>
                        <div class="rounded-3xl border border-border bg-white/85 p-4">
                            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Upcoming goals</p>
                            <p class="mt-2 text-2xl font-semibold tracking-tight text-ink">{{ goals_due_soon }}</p>
                            <p class="mt-2 text-sm leading-6 text-muted">Goals ending within the next 7 days.</p>
                        </div>
                    </div>
                </div>
            </section>

            <aside class="rounded-[2rem] border border-border bg-slate-950 p-6 text-white shadow-soft">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-white/55">Catalog performance</p>
                        <h2 class="mt-2 text-xl font-semibold">Most used exercises</h2>
                    </div>
                    <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-white/80">Top 5</span>
                </div>

                <div class="mt-5 space-y-3">
                    {% for exercise in top_exercises %}
                        <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
                            <div class="flex items-center justify-between gap-3">
                                <p class="text-sm font-semibold text-white">{{ exercise.name }}</p>
                                <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-slate-950">
                                    {{ exercise.sessions }} sessions
                                </span>
                            </div>
                        </div>
                    {% else %}
                        <p class="rounded-3xl border border-white/10 bg-white/5 p-4 text-sm leading-6 text-white/70">
                            No sessions yet. Once users start completing exercises, this panel will rank the most used items.
                        </p>
                    {% endfor %}
                </div>
            </aside>
        </div>

        <div class="grid gap-6 xl:grid-cols-2">
            <section class="rounded-[2rem] border border-border bg-white/90 p-6 shadow-soft">
                <div class="flex flex-col gap-2 border-b border-border/80 pb-4 sm:flex-row sm:items-end sm:justify-between">
                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand">Recent users</p>
                        <h2 class="mt-2 text-xl font-semibold text-ink">Latest registrations</h2>
                    </div>
                </div>

                <div class="mt-5 overflow-x-auto">
                    <table class="min-w-full border-collapse">
                        <thead>
                            <tr class="border-b border-border">
                                <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted">Name</th>
                                <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted">Email</th>
                                <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted">Role</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for user in recent_users %}
                                <tr class="border-b border-border/70 last:border-b-0">
                                    <td class="px-3 py-4 text-sm font-medium text-ink">{{ user.prenomU }} {{ user.nomU }}</td>
                                    <td class="px-3 py-4 text-sm text-muted">{{ user.emailU }}</td>
                                    <td class="px-3 py-4 text-sm text-ink">
                                        <span class="inline-flex rounded-full bg-brand-soft px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-brand">
                                            {{ user.roleU }}
                                        </span>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="3" class="px-3 py-6 text-sm text-muted">No users found.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="rounded-[2rem] border border-border bg-white/90 p-6 shadow-soft">
                <div class="flex flex-col gap-2 border-b border-border/80 pb-4 sm:flex-row sm:items-end sm:justify-between">
                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand">Recent sessions</p>
                        <h2 class="mt-2 text-xl font-semibold text-ink">Latest exercise activity</h2>
                    </div>
                </div>

                <div class="mt-5 overflow-x-auto">
                    <table class="min-w-full border-collapse">
                        <thead>
                            <tr class="border-b border-border">
                                <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted">User</th>
                                <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted">Exercise</th>
                                <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted">Progress</th>
                                <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted">Status</th>
                                <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted">Started</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for session in recent_sessions %}
                                <tr class="border-b border-border/70 last:border-b-0">
                                    <td class="px-3 py-4 text-sm text-ink">{{ session.user ? session.user.emailU : 'N/A' }}</td>
                                    <td class="px-3 py-4 text-sm text-muted">{{ session.exercice ? session.exercice.nom : 'N/A' }}</td>
                                    <td class="px-3 py-4 text-sm text-ink">
                                        <span class="inline-flex rounded-full bg-accent-soft px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-ink">
                                            {{ session.progress ?? 0 }}%
                                        </span>
                                    </td>
                                    <td class="px-3 py-4 text-sm text-ink">
                                        <span class="inline-flex rounded-full bg-brand-soft px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-brand">
                                            {{ session.terminee ? 'Completed' : 'In progress' }}
                                        </span>
                                    </td>
                                    <td class="px-3 py-4 text-sm text-muted">{{ session.dateDebut ? session.dateDebut|date('Y-m-d H:i') : '-' }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" class="px-3 py-6 text-sm text-muted">No sessions found.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </section>
{% endblock %}
