{% extends 'layouts/admin_base.html.twig' %}

{% block page_title %}Gestion Objectifs Personnelles{% endblock %}

{% block content %}
    <div class="page-stack">
        {{ component('PageHeader', {
            eyebrow: 'Administration',
            title: 'Gestion Objectifs Personnelles',
            copy: 'Consultez les 4 modules et gerer les enregistrements depuis le back office.'
        }) }}

        <section class="feature-grid">
            {% for module in modules %}
                <article class="feature-card">
                    <h3 class="feature-title">{{ module.title }}</h3>
                    <p class="feature-copy">{{ module.description }}</p>
                    <a class="btn-primary mt-4" href="{{ path(module.route) }}">Ouvrir</a>
                </article>
            {% endfor %}
        </section>
    </div>
{% endblock %}
