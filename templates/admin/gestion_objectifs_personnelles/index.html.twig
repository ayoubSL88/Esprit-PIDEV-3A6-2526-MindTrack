{% endblock %}

{% block content %}
    <div style="padding: 20px;">
        <section class="admin-header">
            <h1>
                <span>📊</span> Gestion des objectifs personnelles
            </h1>
            <p>L'admin peut consulter les données des 4 entités et supprimer les enregistrements.</p>
        </section>

        <!-- Statistiques (optionnel - si tu as des counts) -->
        <div class="stats-banner">
            <div class="stat-card">
                <div class="stat-number">{{ modules|length }}</div>
                <div class="stat-label">Modules disponibles</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">4</div>
                <div class="stat-label">Entités gérées</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">✓</div>
                <div class="stat-label"> Un objectif sans plan n’est qu’un souhait.</div>
            </div>
        </div>

        <section class="admin-grid">
            {% for module in modules %}
                <div class="admin-card">
                    <div class="admin-card-header">
                        <div class="admin-card-icon">
                            {% if module.title == "Objectifs" %}
                                🎯
                            {% elseif module.title == "Plans d'action" %}
                                📋
                            {% elseif module.title == "Jalons de progression" %}
                                📍
                            {% elseif module.title == "Planificateur intelligent" %}
                                🤖
                            {% else %}
                                📦
                            {% endif %}
                        </div>
                        <div>
                            <h3>{{ module.title }}</h3>
                        </div>
                    </div>
                    <div class="admin-card-body">
                        <p>{{ module.description }}</p>
                    </div>
                    <div class="admin-card-footer">
                        <a class="btn-admin-module" href="{{ path(module.route) }}">
                            Gérer →
                        </a>
                    </div>
                </div>
            {% endfor %}
        </section>
        
        <hr>
        
        <div style="font-size: 0.7rem; color: #6c757d; text-align: center; margin-top: 20px;">
            🔒 Interface d'administration - Gestion complète des objectifs personnelles
        </div>
    </div>
{% endblock %}