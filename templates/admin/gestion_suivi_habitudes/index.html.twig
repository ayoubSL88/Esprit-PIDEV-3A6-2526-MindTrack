{% extends 'layouts/admin_base.html.twig' %}

{% block page_title %}Gestion Suivi Habitudes{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const content = document.querySelector('[data-admin-live-content]');
            if (!content) {
                return;
            }

            let controller = null;

            const bindLiveForms = () => {
                content.querySelectorAll('[data-live-admin-form]').forEach(form => {
                    form.addEventListener('submit', event => {
                        event.preventDefault();
                        runRequest(new FormData(form));
                    });

                    form.querySelectorAll('input, select').forEach(field => {
                        field.addEventListener(field.tagName === 'SELECT' ? 'change' : 'input', () => {
                            clearTimeout(field._liveTimer);
                            field._liveTimer = setTimeout(() => runRequest(new FormData(form)), 220);
                        });
                    });

                    const resetButton = form.querySelector('[data-live-reset]');
                    if (resetButton) {
                        resetButton.addEventListener('click', () => {
                            form.reset();
                            runRequest(new FormData(form));
                        });
                    }
                });
            };

            const runRequest = formData => {
                const scrollY = window.scrollY;
                const params = new URLSearchParams(formData);
                const url = `${window.location.pathname}?${params.toString()}`;

                if (controller) {
                    controller.abort();
                }

                controller = new AbortController();
                content.classList.add('opacity-60', 'pointer-events-none');

                fetch(url, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    signal: controller.signal,
                })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Request failed');
                        }

                        return response.text();
                    })
                    .then(html => {
                        content.innerHTML = html;
                        window.history.replaceState({}, '', url);
                        window.scrollTo({ top: scrollY, behavior: 'auto' });
                        bindLiveForms();
                    })
                    .catch(error => {
                        if (error.name !== 'AbortError') {
                            console.error(error);
                        }
                    })
                    .finally(() => {
                        content.classList.remove('opacity-60', 'pointer-events-none');
                    });
            };

            bindLiveForms();
        });
    </script>
{% endblock %}

{% block content %}
    <div class="page-stack">
        {{ component('PageHeader', {
            eyebrow: 'Administration',
            title: 'Back office habitudes',
            copy: 'Module admin pour gerer les habitudes, les suivis et les rappels avec CRUD complet, controles de saisie, recherche, tri et filtre.'
        }) }}

        <div class="button-row">
            <a class="btn-primary" href="{{ path('admin_gestion_suivi_habitudes_habitude_new') }}">Nouvelle habitude</a>
            <a class="btn-secondary" href="{{ path('admin_gestion_suivi_habitudes_suivi_new') }}">Nouveau suivi</a>
            <a class="btn-secondary" href="{{ path('admin_gestion_suivi_habitudes_rappel_new') }}">Nouveau rappel</a>
        </div>

        <div data-admin-live-content class="space-y-6">
            {% include 'admin/gestion_suivi_habitudes/_content.html.twig' %}
        </div>
    </div>
{% endblock %}
