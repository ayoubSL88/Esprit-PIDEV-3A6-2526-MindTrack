{% for label, messages in app.flashes %}
    {% set tone = label in ['error', 'danger'] ? 'flash-error' : 'flash-success' %}
    {% for message in messages %}
        <div class="flash {{ tone }}">{{ message }}</div>
    {% endfor %}
{% endfor %}

<section class="feature-grid">
    <article class="feature-card"><p class="feature-label">Habitudes</p><p class="feature-title">{{ stats.habitudes }}</p></article>
    <article class="feature-card"><p class="feature-label">Booleennes</p><p class="feature-title">{{ stats.habitudes_boolean }}</p></article>
    <article class="feature-card"><p class="feature-label">Numeriques</p><p class="feature-title">{{ stats.habitudes_numeric }}</p></article>
    <article class="feature-card"><p class="feature-label">Suivis completes</p><p class="feature-title">{{ stats.suivis_completed }}/{{ stats.suivis }}</p></article>
    <article class="feature-card"><p class="feature-label">Rappels actifs</p><p class="feature-title">{{ stats.rappels_actifs }}/{{ stats.rappels }}</p></article>
</section>

<section class="page-stack">
    <article class="panel-section page-stack">
        <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
                <h2 class="panel-title">Habitudes</h2>
                <p class="panel-copy">Recherche, tri et filtre sur les habitudes.</p>
            </div>
            <a class="btn-primary" href="{{ path('admin_gestion_suivi_habitudes_habitude_new') }}">Ajouter</a>
        </div>
        <form method="get" class="grid gap-4 lg:grid-cols-5" data-live-admin-form>
            <input class="field-input" type="text" name="hab_q" placeholder="Recherche..." value="{{ habitudeFilters.q }}">
            <select class="field-select" name="hab_frequence"><option value="">Toutes les frequences</option><option value="QUOTIDIEN" {{ habitudeFilters.frequence == 'QUOTIDIEN' ? 'selected' : '' }}>Quotidien</option><option value="HEBDOMADAIRE" {{ habitudeFilters.frequence == 'HEBDOMADAIRE' ? 'selected' : '' }}>Hebdomadaire</option><option value="MENSUEL" {{ habitudeFilters.frequence == 'MENSUEL' ? 'selected' : '' }}>Mensuel</option></select>
            <select class="field-select" name="hab_type"><option value="">Tous les types</option><option value="BOOLEAN" {{ habitudeFilters.habitType == 'BOOLEAN' ? 'selected' : '' }}>Booleen</option><option value="NUMERIC" {{ habitudeFilters.habitType == 'NUMERIC' ? 'selected' : '' }}>Numerique</option></select>
            <select class="field-select" name="hab_sort"><option value="nom" {{ habitudeFilters.sort == 'nom' ? 'selected' : '' }}>Tri: nom</option><option value="frequence" {{ habitudeFilters.sort == 'frequence' ? 'selected' : '' }}>Tri: frequence</option><option value="type" {{ habitudeFilters.sort == 'type' ? 'selected' : '' }}>Tri: type</option><option value="target" {{ habitudeFilters.sort == 'target' ? 'selected' : '' }}>Tri: valeur cible</option></select>
            <select class="field-select" name="hab_direction"><option value="ASC" {{ habitudeFilters.direction == 'ASC' ? 'selected' : '' }}>Croissant</option><option value="DESC" {{ habitudeFilters.direction == 'DESC' ? 'selected' : '' }}>Decroissant</option></select>
            <div class="button-row lg:col-span-5">
                <button class="btn-secondary" type="submit">Appliquer</button>
                <button class="btn-secondary" type="button" data-live-reset>Reinitialiser</button>
            </div>
        </form>
        {% if habitudes is empty %}
            <p class="table-empty">Aucune habitude ne correspond aux filtres.</p>
        {% else %}
            <div class="table-shell"><div class="table-wrap"><table class="table"><thead class="table-head"><tr><th class="table-th">ID</th><th class="table-th">Nom</th><th class="table-th">Frequence</th><th class="table-th">Type</th><th class="table-th">Valeur cible</th><th class="table-th">Unite</th><th class="table-th">Objectif</th><th class="table-th">Actions</th></tr></thead><tbody>{% for habitude in habitudes %}<tr><td class="table-td">#{{ habitude.idHabitude }}</td><td class="table-td">{{ habitude.nom }}</td><td class="table-td">{{ habitude.frequence|title }}</td><td class="table-td"><span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold {{ habitude.habitType == 'BOOLEAN' ? 'bg-success-soft text-success' : 'bg-accent-soft text-emphasis' }}">{{ habitude.habitType }}</span></td><td class="table-td">{{ habitude.targetValue }}</td><td class="table-td">{{ habitude.unit }}</td><td class="table-td">{{ habitude.objectif }}</td><td class="table-td"><div class="button-row"><a class="btn-secondary px-4 py-2" href="{{ path('admin_gestion_suivi_habitudes_habitude_edit', {idHabitude: habitude.idHabitude}) }}">Modifier</a><form method="post" action="{{ path('admin_gestion_suivi_habitudes_habitude_delete', {idHabitude: habitude.idHabitude}) }}" onsubmit="return confirm('Supprimer cette habitude ?');"><input type="hidden" name="_token" value="{{ csrf_token('delete_habitude_' ~ habitude.idHabitude) }}"><button class="btn-danger px-4 py-2" type="submit">Supprimer</button></form></div></td></tr>{% endfor %}</tbody></table></div></div>
        {% endif %}
    </article>

    <article class="panel-section page-stack">
        <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
                <h2 class="panel-title">Suivis</h2>
                <p class="panel-copy">Filtre par habitude, etat et tri.</p>
            </div>
            <a class="btn-primary" href="{{ path('admin_gestion_suivi_habitudes_suivi_new') }}">Ajouter</a>
        </div>
        <form method="get" class="grid gap-4 lg:grid-cols-5" data-live-admin-form>
            <input class="field-input" type="text" name="suivi_q" placeholder="Recherche habitude..." value="{{ suiviFilters.q }}">
            <select class="field-select" name="suivi_habitude"><option value="">Toutes les habitudes</option>{% for habitude in habitudeChoices %}<option value="{{ habitude.idHabitude }}" {{ suiviFilters.habitude == (habitude.idHabitude ~ '') ? 'selected' : '' }}>{{ habitude.nom }}</option>{% endfor %}</select>
            <select class="field-select" name="suivi_etat"><option value="">Tous les etats</option><option value="1" {{ suiviFilters.etat == '1' ? 'selected' : '' }}>Complete</option><option value="0" {{ suiviFilters.etat == '0' ? 'selected' : '' }}>Non complete</option></select>
            <select class="field-select" name="suivi_sort"><option value="date" {{ suiviFilters.sort == 'date' ? 'selected' : '' }}>Tri: date</option><option value="etat" {{ suiviFilters.sort == 'etat' ? 'selected' : '' }}>Tri: etat</option><option value="valeur" {{ suiviFilters.sort == 'valeur' ? 'selected' : '' }}>Tri: valeur</option><option value="habitude" {{ suiviFilters.sort == 'habitude' ? 'selected' : '' }}>Tri: habitude</option></select>
            <select class="field-select" name="suivi_direction"><option value="DESC" {{ suiviFilters.direction == 'DESC' ? 'selected' : '' }}>Decroissant</option><option value="ASC" {{ suiviFilters.direction == 'ASC' ? 'selected' : '' }}>Croissant</option></select>
            <div class="button-row lg:col-span-5">
                <button class="btn-secondary" type="submit">Appliquer</button>
                <button class="btn-secondary" type="button" data-live-reset>Reinitialiser</button>
            </div>
        </form>
        {% if suivis is empty %}
            <p class="table-empty">Aucun suivi disponible.</p>
        {% else %}
            <div class="table-shell"><div class="table-wrap"><table class="table"><thead class="table-head"><tr><th class="table-th">ID</th><th class="table-th">Habitude</th><th class="table-th">Date</th><th class="table-th">Etat</th><th class="table-th">Valeur</th><th class="table-th">Actions</th></tr></thead><tbody>{% for suivi in suivis %}<tr><td class="table-td">#{{ suivi.idSuivi }}</td><td class="table-td">{{ suivi.idHabitude ? suivi.idHabitude.nom : 'N/A' }}</td><td class="table-td">{{ suivi.date ? suivi.date|date('d/m/Y') : '-' }}</td><td class="table-td"><span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold {{ suivi.etat ? 'bg-success-soft text-success' : 'bg-accent-soft text-emphasis' }}">{{ suivi.etat ? 'Complete' : 'En attente' }}</span></td><td class="table-td">{{ suivi.valeur }}</td><td class="table-td"><div class="button-row"><a class="btn-secondary px-4 py-2" href="{{ path('admin_gestion_suivi_habitudes_suivi_edit', {idSuivi: suivi.idSuivi}) }}">Modifier</a><form method="post" action="{{ path('admin_gestion_suivi_habitudes_suivi_delete', {idSuivi: suivi.idSuivi}) }}" onsubmit="return confirm('Supprimer ce suivi ?');"><input type="hidden" name="_token" value="{{ csrf_token('delete_suivi_' ~ suivi.idSuivi) }}"><button class="btn-danger px-4 py-2" type="submit">Supprimer</button></form></div></td></tr>{% endfor %}</tbody></table></div></div>
        {% endif %}
    </article>

    <article class="panel-section page-stack">
        <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
                <h2 class="panel-title">Rappels</h2>
                <p class="panel-copy">Recherche, activation et tri des rappels.</p>
            </div>
            <a class="btn-primary" href="{{ path('admin_gestion_suivi_habitudes_rappel_new') }}">Ajouter</a>
        </div>
        <form method="get" class="grid gap-4 lg:grid-cols-5" data-live-admin-form>
            <input class="field-input" type="text" name="rappel_q" placeholder="Recherche..." value="{{ rappelFilters.q }}">
            <select class="field-select" name="rappel_habitude"><option value="">Toutes les habitudes</option>{% for habitude in habitudeChoices %}<option value="{{ habitude.idHabitude }}" {{ rappelFilters.habitude == (habitude.idHabitude ~ '') ? 'selected' : '' }}>{{ habitude.nom }}</option>{% endfor %}</select>
            <select class="field-select" name="rappel_actif"><option value="">Tous</option><option value="1" {{ rappelFilters.actif == '1' ? 'selected' : '' }}>Actif</option><option value="0" {{ rappelFilters.actif == '0' ? 'selected' : '' }}>Inactif</option></select>
            <select class="field-select" name="rappel_sort"><option value="created" {{ rappelFilters.sort == 'created' ? 'selected' : '' }}>Tri: creation</option><option value="heure" {{ rappelFilters.sort == 'heure' ? 'selected' : '' }}>Tri: heure</option><option value="actif" {{ rappelFilters.sort == 'actif' ? 'selected' : '' }}>Tri: actif</option><option value="habitude" {{ rappelFilters.sort == 'habitude' ? 'selected' : '' }}>Tri: habitude</option></select>
            <select class="field-select" name="rappel_direction"><option value="DESC" {{ rappelFilters.direction == 'DESC' ? 'selected' : '' }}>Decroissant</option><option value="ASC" {{ rappelFilters.direction == 'ASC' ? 'selected' : '' }}>Croissant</option></select>
            <div class="button-row lg:col-span-5">
                <button class="btn-secondary" type="submit">Appliquer</button>
                <button class="btn-secondary" type="button" data-live-reset>Reinitialiser</button>
            </div>
        </form>
        {% if rappels is empty %}
            <p class="table-empty">Aucun rappel disponible.</p>
        {% else %}
            <div class="table-shell"><div class="table-wrap"><table class="table"><thead class="table-head"><tr><th class="table-th">ID</th><th class="table-th">Habitude</th><th class="table-th">Heure</th><th class="table-th">Jours</th><th class="table-th">Etat</th><th class="table-th">Message</th><th class="table-th">Creation</th><th class="table-th">Actions</th></tr></thead><tbody>{% for rappel in rappels %}<tr><td class="table-td">#{{ rappel.idRappel }}</td><td class="table-td">{{ rappel.idHabitude ? rappel.idHabitude.nom : 'N/A' }}</td><td class="table-td">{{ rappel.heureRappel }}</td><td class="table-td">{{ rappel.jours }}</td><td class="table-td"><span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold {{ rappel.actif ? 'bg-success-soft text-success' : 'bg-accent-soft text-emphasis' }}">{{ rappel.actif ? 'Actif' : 'Inactif' }}</span></td><td class="table-td">{{ rappel.message }}</td><td class="table-td">{{ rappel.createdAt ? rappel.createdAt|date('d/m/Y H:i') : '-' }}</td><td class="table-td"><div class="button-row"><a class="btn-secondary px-4 py-2" href="{{ path('admin_gestion_suivi_habitudes_rappel_edit', {idRappel: rappel.idRappel}) }}">Modifier</a><form method="post" action="{{ path('admin_gestion_suivi_habitudes_rappel_delete', {idRappel: rappel.idRappel}) }}" onsubmit="return confirm('Supprimer ce rappel ?');"><input type="hidden" name="_token" value="{{ csrf_token('delete_rappel_' ~ rappel.idRappel) }}"><button class="btn-danger px-4 py-2" type="submit">Supprimer</button></form></div></td></tr>{% endfor %}</tbody></table></div></div>
        {% endif %}
    </article>
</section>
