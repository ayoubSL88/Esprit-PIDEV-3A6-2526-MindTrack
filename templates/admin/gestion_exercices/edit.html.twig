{% extends 'layouts/admin_base.html.twig' %}

{% block page_title %}Modifier l'exercice{% endblock %}

{% block content %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Modifier exercice</h1>
        <a href="{{ path('admin_gestion_exercices_index') }}" class="btn btn-secondary">Retour</a>
    </div>

    <div class="card">
        <div class="card-body">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                
                {% if form.vars.submitted %}
                    {{ form_errors(form) }}
                {% endif %}

                <div class="row">
                    <div class="col-md-6">
                        {{ form_label(form.nom) }}
                        {{ form_widget(form.nom) }}
                        {% if form.nom.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block text-danger">
                                {{ form_errors(form.nom) }}
                            </div>
                        {% endif %}
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.type) }}
                        {{ form_widget(form.type) }}
                        {% if form.type.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block text-danger">
                                {{ form_errors(form.type) }}
                            </div>
                        {% endif %}
                    </div>
                </div>
                
                <div class="row mt-3">
                    <div class="col-md-6">
                        {{ form_label(form.duree) }}
                        {{ form_widget(form.duree) }}
                        {% if form.duree.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block text-danger">
                                {{ form_errors(form.duree) }}
                            </div>
                        {% endif %}
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.difficulte) }}
                        {{ form_widget(form.difficulte) }}
                        {% if form.difficulte.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block text-danger">
                                {{ form_errors(form.difficulte) }}
                            </div>
                        {% endif %}
                    </div>
                </div>
                
                <div class="mt-3">
                    {{ form_label(form.description) }}
                    {{ form_widget(form.description) }}
                    {% if form.description.vars.errors|length > 0 %}
                        <div class="invalid-feedback d-block text-danger">
                            {{ form_errors(form.description) }}
                        </div>
                    {% endif %}
                </div>
                
                <div class="mt-3">
                    {{ form_label(form.demarche) }}
                    {{ form_widget(form.demarche) }}
                    {% if form.demarche.vars.errors|length > 0 %}
                        <div class="invalid-feedback d-block text-danger">
                            {{ form_errors(form.demarche) }}
                        </div>
                    {% endif %}
                </div>

                {% if form.date_creation is defined %}
                    <div class="row mt-3">
                        <div class="col-md-6">
                            {{ form_label(form.date_creation) }}
                            {{ form_widget(form.date_creation) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_label(form.date_modification) }}
                            {{ form_widget(form.date_modification) }}
                        </div>
                    </div>
                {% endif %}

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Mettre à jour</button>
                    <a href="{{ path('admin_gestion_exercices_index') }}" class="btn btn-secondary">Annuler</a>
                </div>
                
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}