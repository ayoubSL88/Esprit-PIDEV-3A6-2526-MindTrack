{% extends 'layouts/admin_base.html.twig' %}

{% block page_title %}Modifier l'exercice{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            flex-wrap: wrap;
            gap: 16px;
        }
        
        .admin-header h1 {
            font-size: 1.8rem;
            font-weight: 700;
            background: linear-gradient(135deg, #1e293b, #475569);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 0;
        }
        
        .form-card {
            background: white;
            border-radius: 28px;
            padding: 32px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.05);
            border: 1px solid #f1f5f9;
            max-width: 900px;
            margin: 0 auto;
        }
        
        .form-group {
            margin-bottom: 24px;
        }
        
        .form-group label {
            display: block;
            font-weight: 600;
            font-size: 0.85rem;
            color: #1e293b;
            margin-bottom: 8px;
        }
        
        .form-control {
            width: 100%;
            padding: 12px 16px;
            border: 1.5px solid #e2e8f0;
            border-radius: 14px;
            font-size: 0.9rem;
            transition: all 0.2s;
            background: #f8fafc;
        }
        
        .form-control:focus {
            border-color: #6366f1;
            outline: none;
            background: white;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
        }
        
        textarea.form-control {
            resize: vertical;
            font-family: inherit;
        }
        
        .form-error {
            color: #ef4444;
            font-size: 0.7rem;
            margin-top: 6px;
        }
        
        .btn-group {
            display: flex;
            gap: 12px;
            margin-top: 32px;
        }
        
        .btn-admin-primary {
            background: linear-gradient(135deg, #f59e0b, #d97706);
            color: white;
            padding: 12px 28px;
            border-radius: 40px;
            border: none;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .btn-admin-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(245,158,11,0.3);
        }
        
        .btn-admin-secondary {
            background: #f1f5f9;
            color: #475569;
            padding: 12px 28px;
            border-radius: 40px;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.2s;
            display: inline-block;
        }
        
        .btn-admin-secondary:hover {
            background: #e2e8f0;
            transform: translateY(-1px);
        }
        
        .row {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }
        
        @media (max-width: 640px) {
            .row {
                grid-template-columns: 1fr;
                gap: 16px;
            }
            .form-card {
                padding: 24px;
            }
            .admin-header {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
{% endblock %}

{% block content %}
<div style="max-width: 1000px; margin: 0 auto; padding: 20px;">
    <!-- EN-TÊTE -->
    <div class="admin-header">
        <h1>✏️ Modifier l'exercice</h1>
        <a href="{{ path('admin_gestion_exercices_index') }}" class="btn-admin-secondary">← Retour</a>
    </div>

    <!-- FORMULAIRE -->
    <div class="form-card">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            
            {% if form.vars.submitted and not form.vars.valid %}
                <div style="background: #fef2f2; border-radius: 16px; padding: 16px; margin-bottom: 24px; color: #dc2626; font-size: 0.85rem;">
                    ⚠️ Veuillez corriger les erreurs ci-dessous
                </div>
            {% endif %}

            <div class="row">
                <div class="form-group">
                    {{ form_label(form.nom) }}
                    {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                    {% if form.nom.vars.errors|length > 0 %}
                        <div class="form-error">{{ form_errors(form.nom) }}</div>
                    {% endif %}
                </div>
                <div class="form-group">
                    {{ form_label(form.type) }}
                    {{ form_widget(form.type, {'attr': {'class': 'form-control'}}) }}
                    {% if form.type.vars.errors|length > 0 %}
                        <div class="form-error">{{ form_errors(form.type) }}</div>
                    {% endif %}
                </div>
            </div>

            <div class="row">
                <div class="form-group">
                    {{ form_label(form.duree) }}
                    {{ form_widget(form.duree, {'attr': {'class': 'form-control'}}) }}
                    {% if form.duree.vars.errors|length > 0 %}
                        <div class="form-error">{{ form_errors(form.duree) }}</div>
                    {% endif %}
                </div>
                <div class="form-group">
                    {{ form_label(form.difficulte) }}
                    {{ form_widget(form.difficulte, {'attr': {'class': 'form-control'}}) }}
                    {% if form.difficulte.vars.errors|length > 0 %}
                        <div class="form-error">{{ form_errors(form.difficulte) }}</div>
                    {% endif %}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                {% if form.description.vars.errors|length > 0 %}
                    <div class="form-error">{{ form_errors(form.description) }}</div>
                {% endif %}
            </div>

            <div class="form-group">
                {{ form_label(form.demarche) }}
                {{ form_widget(form.demarche, {'attr': {'class': 'form-control', 'rows': 6}}) }}
                <small class="text-muted" style="font-size: 0.7rem; color: #94a3b8;">💡 Séparez chaque étape par un retour à la ligne</small>
                {% if form.demarche.vars.errors|length > 0 %}
                    <div class="form-error">{{ form_errors(form.demarche) }}</div>
                {% endif %}
            </div>

            <div class="btn-group">
                <button type="submit" class="btn-admin-primary">🔄 Mettre à jour</button>
                <a href="{{ path('admin_gestion_exercices_index') }}" class="btn-admin-secondary">Annuler</a>
            </div>
            
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}