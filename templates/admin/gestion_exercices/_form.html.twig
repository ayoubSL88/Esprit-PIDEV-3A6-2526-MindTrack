{{ form_start(form, {'attr': {'class': 'needs-validation'}}) }}
    {{ form_errors(form) }}

    <div class="row">
        <div class="col-md-6">
            {{ form_row(form.nom, {'attr': {'class': 'form-control'}}) }}
        </div>
        <div class="col-md-6">
            {{ form_row(form.type, {'attr': {'class': 'form-control'}}) }}
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            {{ form_row(form.duree, {'attr': {'class': 'form-control'}}) }}
        </div>
        <div class="col-md-6">
            {{ form_row(form.difficulte, {'attr': {'class': 'form-control'}}) }}
        </div>
    </div>

    {{ form_row(form.description, {'attr': {'class': 'form-control'}}) }}
    {{ form_row(form.demarche, {'attr': {'class': 'form-control'}}) }}

    <div class="row">
        <div class="col-md-6">
            {{ form_row(form.date_creation, {'attr': {'class': 'form-control'}}) }}
        </div>
        <div class="col-md-6">
            {{ form_row(form.date_modification, {'attr': {'class': 'form-control'}}) }}
        </div>
    </div>

    <button type="submit" class="btn btn-primary mt-3">{{ button_label|default('Enregistrer') }}</button>
{{ form_end(form) }}
