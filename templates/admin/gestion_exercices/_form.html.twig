{% extends 'layouts/admin_base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .admin-form {
            max-width: 900px;
            margin: 0 auto;
        }
        
        .form-card {
            background: white;
            border-radius: 28px;
            padding: 32px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.05);
            border: 1px solid #f1f5f9;
        }
        
        .form-group {
            margin-bottom: 24px;
        }
        
        .form-group label {
            display: block;
            font-weight: 600;
            font-size: 0.85rem;
            color: #1e293b;
            margin-bottom: 8px;
        }
        
        .form-group label .required {
            color: #ef4444;
            margin-left: 4px;
        }
        
        .form-control {
            width: 100%;
            padding: 12px 16px;
            border: 1.5px solid #e2e8f0;
            border-radius: 14px;
            font-size: 0.9rem;
            transition: all 0.2s;
            background: #f8fafc;
        }
        
        .form-control:focus {
            border-color: #6366f1;
            outline: none;
            background: white;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
        }
        
        textarea.form-control {
            resize: vertical;
            font-family: inherit;
        }
        
        select.form-control {
            cursor: pointer;
        }
        
        .form-error {
            color: #ef4444;
            font-size: 0.7rem;
            margin-top: 6px;
        }
        
        .row {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }
        
        .btn-submit {
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            color: white;
            padding: 12px 28px;
            border-radius: 40px;
            border: none;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 16px;
        }
        
        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(99,102,241,0.3);
        }
        
        @media (max-width: 640px) {
            .row {
                grid-template-columns: 1fr;
                gap: 16px;
            }
            .form-card {
                padding: 24px;
            }
        }
    </style>
{% endblock %}

{% block content %}
<div class="admin-form">
    <div class="form-card">
        {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
        
            {% if form.vars.submitted and not form.vars.valid %}
                <div style="background: #fef2f2; border-radius: 16px; padding: 16px; margin-bottom: 24px; color: #dc2626; font-size: 0.85rem;">
                    ⚠️ Veuillez corriger les erreurs ci-dessous
                </div>
            {% endif %}
        
            <div class="row">
                <div class="form-group">
                    {{ form_label(form.nom) }}
                    {{ form_widget(form.nom, {'attr': {'class': 'form-control', 'placeholder': 'Nom de l\'exercice'}}) }}
                    {% if form.nom.vars.errors|length > 0 %}
                        <div class="form-error">{{ form_errors(form.nom) }}</div>
                    {% endif %}
                </div>
                <div class="form-group">
                    {{ form_label(form.type) }}
                    {{ form_widget(form.type, {'attr': {'class': 'form-control', 'placeholder': 'Type (ex: Méditation, Yoga...)'}}) }}
                    {% if form.type.vars.errors|length > 0 %}
                        <div class="form-error">{{ form_errors(form.type) }}</div>
                    {% endif %}
                </div>
            </div>
        
            <div class="row">
                <div class="form-group">
                    {{ form_label(form.duree) }}
                    {{ form_widget(form.duree, {'attr': {'class': 'form-control', 'placeholder': 'Durée en minutes'}}) }}
                    {% if form.duree.vars.errors|length > 0 %}
                        <div class="form-error">{{ form_errors(form.duree) }}</div>
                    {% endif %}
                </div>
                <div class="form-group">
                    {{ form_label(form.difficulte) }}
                    {{ form_widget(form.difficulte, {'attr': {'class': 'form-control'}}) }}
                    {% if form.difficulte.vars.errors|length > 0 %}
                        <div class="form-error">{{ form_errors(form.difficulte) }}</div>
                    {% endif %}
                </div>
            </div>
        
            <div class="form-group">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4, 'placeholder': 'Description détaillée de l\'exercice...'}}) }}
                {% if form.description.vars.errors|length > 0 %}
                    <div class="form-error">{{ form_errors(form.description) }}</div>
                {% endif %}
            </div>
        
            <div class="form-group">
                {{ form_label(form.demarche) }}
                {{ form_widget(form.demarche, {'attr': {'class': 'form-control', 'rows': 6, 'placeholder': 'Étapes à suivre (une par ligne)...'}}) }}
                <small style="font-size: 0.7rem; color: #94a3b8;">💡 Séparez chaque étape par un retour à la ligne</small>
                {% if form.demarche.vars.errors|length > 0 %}
                    <div class="form-error">{{ form_errors(form.demarche) }}</div>
                {% endif %}
            </div>
        
            {% if form.date_creation is defined %}
                <div class="row">
                    <div class="form-group">
                        {{ form_label(form.date_creation) }}
                        {{ form_widget(form.date_creation, {'attr': {'class': 'form-control'}}) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.date_modification) }}
                        {{ form_widget(form.date_modification, {'attr': {'class': 'form-control'}}) }}
                    </div>
                </div>
            {% endif %}
        
            <button type="submit" class="btn-submit">
                {{ button_label|default('✅ Enregistrer') }}
            </button>
            
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}