{% extends 'layouts/admin_base.html.twig' %}

{% block page_title %}Détails de l'exercice{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            flex-wrap: wrap;
            gap: 16px;
        }
        
        .admin-header h1 {
            font-size: 1.8rem;
            font-weight: 700;
            background: linear-gradient(135deg, #1e293b, #475569);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 0;
        }
        
        .detail-card {
            background: white;
            border-radius: 28px;
            overflow: hidden;
            box-shadow: 0 8px 30px rgba(0,0,0,0.05);
            border: 1px solid #f1f5f9;
        }
        
        .detail-header {
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            padding: 20px 28px;
            color: white;
        }
        
        .detail-header h2 {
            margin: 0;
            font-size: 1.3rem;
            font-weight: 600;
        }
        
        .detail-body {
            padding: 28px;
        }
        
        .detail-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
        }
        
        .detail-item {
            border-bottom: 1px solid #f1f5f9;
            padding-bottom: 16px;
        }
        
        .detail-item.full-width {
            grid-column: span 2;
        }
        
        .detail-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #94a3b8;
            margin-bottom: 6px;
        }
        
        .detail-value {
            font-size: 1rem;
            color: #1e293b;
            line-height: 1.5;
        }
        
        .badge-detail {
            display: inline-block;
            padding: 4px 14px;
            border-radius: 30px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        
        .btn-group {
            display: flex;
            gap: 12px;
        }
        
        .btn-admin-warning {
            background: #fefce8;
            color: #854d0e;
            padding: 10px 20px;
            border-radius: 40px;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        
        .btn-admin-warning:hover {
            background: #fef08a;
            transform: translateY(-1px);
        }
        
        .btn-admin-secondary {
            background: #f1f5f9;
            color: #475569;
            padding: 10px 20px;
            border-radius: 40px;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        
        .btn-admin-secondary:hover {
            background: #e2e8f0;
            transform: translateY(-1px);
        }
        
        @media (max-width: 768px) {
            .detail-grid {
                grid-template-columns: 1fr;
                gap: 16px;
            }
            .detail-item.full-width {
                grid-column: span 1;
            }
            .admin-header {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
{% endblock %}

{% block content %}
<div style="max-width: 1000px; margin: 0 auto; padding: 20px;">
    <!-- EN-TÊTE -->
    <div class="admin-header">
        <h1>📖 {{ exercice.nom }}</h1>
        <div class="btn-group">
            <a href="{{ path('admin_gestion_exercices_edit', {'idEx': exercice.idEx}) }}" class="btn-admin-warning">
                ✏️ Modifier
            </a>
            <a href="{{ path('admin_gestion_exercices_index') }}" class="btn-admin-secondary">
                ← Retour
            </a>
        </div>
    </div>

    <!-- DÉTAILS -->
    <div class="detail-card">
        <div class="detail-header">
            <h2>📋 Informations détaillées</h2>
        </div>
        <div class="detail-body">
            <div class="detail-grid">
                <div class="detail-item">
                    <div class="detail-label">🏷️ Nom</div>
                    <div class="detail-value"><strong>{{ exercice.nom }}</strong></div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">📂 Type</div>
                    <div class="detail-value">{{ exercice.type }}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">⏱️ Durée</div>
                    <div class="detail-value">{{ exercice.duree }} minutes</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">📊 Difficulté</div>
                    <div class="detail-value">
                        {% if exercice.difficulte == 'FACILE' %}
                            <span class="badge-detail" style="background: #d1fae5; color: #065f46;">🟢 Facile</span>
                        {% elseif exercice.difficulte == 'MOYEN' %}
                            <span class="badge-detail" style="background: #fed7aa; color: #9a3412;">🟠 Moyen</span>
                        {% else %}
                            <span class="badge-detail" style="background: #fee2e2; color: #dc2626;">🔴 Difficile</span>
                        {% endif %}
                    </div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">📅 Date de création</div>
                    <div class="detail-value">{{ exercice.dateCreation|date('d/m/Y H:i') }}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">🔄 Dernière modification</div>
                    <div class="detail-value">{{ exercice.dateModification|date('d/m/Y H:i') }}</div>
                </div>
                <div class="detail-item full-width">
                    <div class="detail-label">📝 Description</div>
                    <div class="detail-value">{{ exercice.description|nl2br }}</div>
                </div>
                <div class="detail-item full-width">
                    <div class="detail-label">📋 Démarche</div>
                    <div class="detail-value" style="background: #f8fafc; padding: 16px; border-radius: 16px;">
                        {{ exercice.demarche|nl2br }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}