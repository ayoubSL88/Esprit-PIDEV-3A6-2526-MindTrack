{% extends 'layouts/admin_base.html.twig' %}

{% block page_title %}Nouvel exercice{% endblock %}

{% block content %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Créer un exercice</h1>
        <a href="{{ path('admin_gestion_exercices_index') }}" class="btn btn-secondary">Retour</a>
    </div>

    <div class="card">
        <div class="card-body">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                
                {# Affichage des erreurs globales uniquement si formulaire soumis #}
                {% if form.vars.submitted %}
                    {{ form_errors(form) }}
                {% endif %}

                <div class="row">
                    <div class="col-md-6">
                        {{ form_label(form.nom) }}
                        {{ form_widget(form.nom) }}
                        {% if form.nom.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block text-danger">
                                {{ form_errors(form.nom) }}
                            </div>
                        {% else %}
                            <small class="text-muted"></small>
                        {% endif %}
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.type) }}
                        {{ form_widget(form.type) }}
                        {% if form.type.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block text-danger">
                                {{ form_errors(form.type) }}
                            </div>
                        {% else %}
                            <small class="text-muted"></small>
                        {% endif %}
                    </div>
                </div>
                
                <div class="row mt-3">
                    <div class="col-md-6">
                        {{ form_label(form.duree) }}
                        {{ form_widget(form.duree) }}
                        {% if form.duree.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block text-danger">
                                {{ form_errors(form.duree) }}
                            </div>
                        {% else %}
                            <small class="text-muted"></small>
                        {% endif %}
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.difficulte) }}
                        {{ form_widget(form.difficulte) }}
                        {% if form.difficulte.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block text-danger">
                                {{ form_errors(form.difficulte) }}
                            </div>
                        {% else %}
                            <small class="text-muted">Choisissez le niveau de difficulté</small>
                        {% endif %}
                    </div>
                </div>
                
                <div class="mt-3">
                    {{ form_label(form.description) }}
                    {{ form_widget(form.description) }}
                    {% if form.description.vars.errors|length > 0 %}
                        <div class="invalid-feedback d-block text-danger">
                            {{ form_errors(form.description) }}
                        </div>
                    {% else %}
                        <small class="text-muted"></small>
                    {% endif %}
                </div>
                
                <div class="mt-3">
                    {{ form_label(form.demarche) }}
                    {{ form_widget(form.demarche) }}
                    {% if form.demarche.vars.errors|length > 0 %}
                        <div class="invalid-feedback d-block text-danger">
                            {{ form_errors(form.demarche) }}
                        </div>
                    {% else %}
                        <small class="text-muted"></small>
                    {% endif %}
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                    <a href="{{ path('admin_gestion_exercices_index') }}" class="btn btn-secondary">Annuler</a>
                </div>
                
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .form-group {
        margin-bottom: 1rem;
    }
    .form-control.is-invalid {
        border-color: #dc3545;
    }
    .invalid-feedback {
        color: #dc3545;
        font-size: 0.875rem;
        margin-top: 0.25rem;
    }
    textarea.form-control {
        resize: vertical;
    }
    .text-muted {
        color: #6c757d !important;
        font-size: 0.875rem;
    }
    .text-danger {
        color: #dc3545 !important;
    }
</style>
{% endblock %}