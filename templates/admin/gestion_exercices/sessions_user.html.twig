{% extends 'layouts/admin_base.html.twig' %}

{% block page_title %}Sessions de {{ user.nomU }} {{ user.prenomU }}{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Sessions de <strong>{{ user.nomU }} {{ user.prenomU }}</strong></h1>
        <p class="text-muted">{{ user.emailU }} | Âge: {{ user.ageU }} ans | Rôle: {{ user.roleU }}</p>
    </div>
    <div>
        <a href="{{ path('admin_sessions_index') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Retour à toutes les sessions
        </a>
    </div>
</div>

<!-- Statistiques utilisateur -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h6 class="card-title">Total sessions</h6>
                <h3 class="mb-0">{{ sessions|length }}</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h6 class="card-title">Exercices terminés</h6>
                <h3 class="mb-0">{{ sessions|filter(s => s.terminee)|length }}</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-info text-white">
            <div class="card-body">
                <h6 class="card-title">Temps total</h6>
                <h3 class="mb-0">
                    {% set totalTime = 0 %}
                    {% for s in sessions %}
                        {% set totalTime = totalTime + (s.dureeReelle|default(0)) %}
                    {% endfor %}
                    {{ (totalTime / 60)|round }} min
                </h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-dark">
            <div class="card-body">
                <h6 class="card-title">Progression moyenne</h6>
                <h3 class="mb-0">
                    {% set avg = 0 %}
                    {% for s in sessions %}
                        {% set avg = avg + s.progress %}
                    {% endfor %}
                    {{ sessions|length > 0 ? (avg / sessions|length)|round : 0 }}%
                </h3>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Exercice</th>
                        <th>Date début</th>
                        <th>Date fin</th>
                        <th>Durée</th>
                        <th>Progression</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for session in sessions %}
                    <tr>
                        <td>#{{ session.idSession }}</td>
                        <td>
                            <strong>{{ session.exercice.nom }}</strong><br>
                            <small class="text-muted">{{ session.exercice.type }} - {{ session.exercice.difficulte }}</small>
                        </td>
                        <td>{{ session.dateDebut|date('d/m/Y H:i') }}</td>
                        <td>
                            {% if session.dateFin %}
                                {{ session.dateFin|date('d/m/Y H:i') }}
                            {% else %}
                                <span class="badge bg-warning">En cours</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if session.dureeReelle %}
                                {{ (session.dureeReelle / 60)|round }} min
                            {% else %}
                                -
                            {% endif %}
                        </td>
                        <td>
                            <div class="progress" style="height: 20px; width: 100px;">
                                <div class="progress-bar bg-{{ session.progress == 100 ? 'success' : 'primary' }}" 
                                     style="width: {{ session.progress }}%">
                                    {{ session.progress }}%
                                </div>
                            </div>
                        </td>
                        <td>
                            {% if session.terminee %}
                                <span class="badge bg-success">Terminée</span>
                            {% else %}
                                <span class="badge bg-warning">En cours</span>
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ path('admin_sessions_show', {'idSession': session.idSession}) }}" 
                               class="btn btn-sm btn-info">
                                <i class="bi bi-eye"></i> Détail
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center py-4">
                            <i class="bi bi-inbox fs-1"></i>
                            <p class="mt-2">Cet utilisateur n'a pas encore de sessions</p>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}