<form method="post" action="{{ path('admin_gestion_exercices_delete', {'idEx': exercice.idEx}) }}" 
      onsubmit="return confirm('⚠️ Êtes-vous sûr de vouloir supprimer définitivement cet exercice ? Cette action est irréversible.');" 
      style="display: inline-block;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ exercice.idEx) }}">
    <button class="btn-admin-danger" style="background: #fef2f2; color: #dc2626; padding: 8px 16px; border-radius: 40px; border: none; cursor: pointer; font-size: 0.75rem; font-weight: 500; transition: all 0.2s; display: inline-flex; align-items: center; gap: 6px;">
        🗑️ Supprimer
    </button>
</form>

<style>
    .btn-admin-danger:hover {
        background: #fee2e2;
        transform: translateY(-1px);
    }
</style>