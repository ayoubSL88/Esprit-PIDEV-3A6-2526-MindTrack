<header class="topbar">
    <div class="container topbar-inner">
        <a class="brand" href="{{ path(office == 'admin' ? 'admin_dashboard' : 'front_home') }}">MindTrack</a>

        <nav class="navlinks">
            {% if office == 'admin' %}
                <a href="{{ path('admin_dashboard') }}">Dashboard</a>
                <a href="{{ path('admin_gestion_objectifs_personnelles_index') }}">Objectifs</a>
                <a href="{{ path('admin_gestion_suivi_habitudes_index') }}">Habitudes</a>
                <a href="{{ path('admin_gestion_exercices_index') }}">Exercices</a>
                <a href="{{ path('admin_gestion_humeur_index') }}">Humeur</a>
                <a href="{{ path('admin_gestion_user_index') }}">Users</a>
                {% if is_granted('ROLE_USER') %}
                    <a href="{{ path('front_home') }}">Front</a>
                {% endif %}
            {% else %}
                <a href="{{ path('front_home') }}">Accueil</a>
                <a href="{{ path('front_gestion_objectifs_personnelles_index') }}">Objectifs</a>
                <a href="{{ path('front_gestion_suivi_habitudes_index') }}">Habitudes</a>
                <a href="{{ path('front_gestion_exercices_index') }}">Exercices</a>
                <a href="{{ path('front_gestion_humeur_index') }}">Humeur</a>
                <a href="{{ path('front_gestion_user_index') }}">Profil</a>
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('admin_dashboard') }}">Admin</a>
                {% endif %}
            {% endif %}

            {% if app.user %}
                <span style="color: var(--muted);">{{ app.user.userIdentifier }}</span>
                <a href="{{ path('app_logout') }}">Logout</a>
            {% else %}
                <a href="{{ path('app_login') }}">Login</a>
            {% endif %}
        </nav>
    </div>
</header>
