<header class="app-navbar">
    <div class="app-shell">
        <div class="app-navbar-inner">
            <a class="app-brand" href="{{ path(office == 'admin' ? 'admin_dashboard' : 'front_home') }}">
                <span class="app-brand-mark">MT</span>
                <span>MindTrack</span>
            </a>

            <nav class="app-nav" aria-label="Primary">
                <div class="app-nav-group">
            {% if office == 'admin' %}
                    <a class="app-nav-link {{ app.request.attributes.get('_route') == 'admin_dashboard' ? 'app-nav-link-active' : '' }}" href="{{ path('admin_dashboard') }}">Dashboard</a>
                    <a class="app-nav-link {{ app.request.attributes.get('_route') starts with 'admin_gestion_user_' ? 'app-nav-link-active' : '' }}" href="{{ path('admin_gestion_user_index') }}">Users</a>
                    <a class="app-nav-link {{ app.request.attributes.get('_route') starts with 'admin_gestion_objectifs_personnelles_' ? 'app-nav-link-active' : '' }}" href="{{ path('admin_gestion_objectifs_personnelles_index') }}">Objectifs</a>
                    <a class="app-nav-link {{ app.request.attributes.get('_route') starts with 'admin_gestion_suivi_habitudes_' ? 'app-nav-link-active' : '' }}" href="{{ path('admin_gestion_suivi_habitudes_index') }}">Habitudes</a>
                    <a class="app-nav-link {{ app.request.attributes.get('_route') starts with 'admin_gestion_exercices_' ? 'app-nav-link-active' : '' }}" href="{{ path('admin_gestion_exercices_index') }}">Exercices</a>
                    <a class="app-nav-link {{ app.request.attributes.get('_route') starts with 'admin_gestion_humeur_' ? 'app-nav-link-active' : '' }}" href="{{ path('admin_gestion_humeur_index') }}">Humeur</a>
            {% else %}
                    <a class="app-nav-link {{ app.request.attributes.get('_route') == 'front_home' ? 'app-nav-link-active' : '' }}" href="{{ path('front_home') }}">Accueil</a>
                    <a class="app-nav-link {{ app.request.attributes.get('_route') starts with 'front_gestion_objectifs_personnelles_' ? 'app-nav-link-active' : '' }}" href="{{ path('front_gestion_objectifs_personnelles_index') }}">Objectifs</a>
                    <a class="app-nav-link {{ app.request.attributes.get('_route') starts with 'front_gestion_suivi_habitudes_' ? 'app-nav-link-active' : '' }}" href="{{ path('front_gestion_suivi_habitudes_index') }}">Habitudes</a>
                    <a class="app-nav-link {{ app.request.attributes.get('_route') starts with 'front_gestion_exercices_' ? 'app-nav-link-active' : '' }}" href="{{ path('front_gestion_exercices_home') }}">Exercices</a>
                    <a class="app-nav-link {{ app.request.attributes.get('_route') starts with 'front_gestion_humeur_' ? 'app-nav-link-active' : '' }}" href="{{ path('front_gestion_humeur_index') }}">Humeur</a>
                    <a class="app-nav-link {{ app.request.attributes.get('_route') starts with 'front_gestion_user_' ? 'app-nav-link-active' : '' }}" href="{{ path('front_gestion_user_index') }}">Profil</a>
            {% endif %}
                </div>

                <div class="app-nav-group">
                    {% if app.user %}
                        <span class="app-nav-meta">{{ app.user.userIdentifier }}</span>
                        <a class="app-nav-link" href="{{ path('app_logout') }}">Logout</a>
                    {% else %}
                        <a class="app-nav-link" href="{{ path('app_login') }}">Login</a>
                    {% endif %}
                </div>
            </nav>
        </div>
    </div>
</header>