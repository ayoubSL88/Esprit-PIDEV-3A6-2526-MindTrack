<section class="panel-section space-y-4">
    <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
            <p class="panel-title">Advanced mood analysis</p>
            <p class="panel-copy">
                Insights and tailored next steps based on the latest tracked week{% if analysis.referenceDate %} ending on {{ analysis.referenceDate|date('Y-m-d') }}{% endif %}.
            </p>
        </div>
        <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold {{ analysis.riskLevel == 'high' ? 'bg-accent-soft text-emphasis' : (analysis.riskLevel == 'medium' ? 'border border-border bg-white/90 text-ink' : 'bg-success-soft text-success') }}">
            {{ analysis.riskLabel }} risk
        </span>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
        {% for card in analysis.cards %}
            <article class="rounded-2xl border border-border bg-white/80 p-4 shadow-soft">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">{{ card.label }}</p>
                <p class="mt-2 text-lg font-semibold text-ink">{{ card.value }}</p>
                <p class="mt-2 text-sm text-muted">{{ card.hint }}</p>
            </article>
        {% endfor %}
    </div>

    <div class="space-y-3">
        {% for alert in analysis.alerts %}
            <article class="rounded-2xl border border-border p-4 shadow-soft {{ alert.severity == 'high' ? 'bg-accent-soft' : (alert.severity == 'medium' ? 'bg-white/90' : 'bg-success-soft') }}">
                <div class="flex flex-wrap items-center gap-2">
                    <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold {{ alert.severity == 'high' ? 'bg-white/90 text-emphasis' : (alert.severity == 'medium' ? 'border border-border bg-white/80 text-ink' : 'bg-white/90 text-success') }}">
                        {{ alert.badge }}
                    </span>
                    <p class="text-sm font-semibold text-ink">{{ alert.title }}</p>
                </div>
                <p class="mt-2 text-sm text-muted">{{ alert.message }}</p>
            </article>
        {% endfor %}
    </div>

    {% if analysis.recommendations is not empty %}
        <div class="space-y-3">
            <div>
                <p class="panel-title">Suggested next steps</p>
                <p class="panel-copy">These recommendations adapt to recent mood patterns and rotate across different ideas so the same tip is not repeated too often.</p>
            </div>

            <div class="grid gap-4 lg:grid-cols-3">
                {% for recommendation in analysis.recommendations %}
                    <article class="rounded-2xl border border-border p-4 shadow-soft {{ recommendation.priority == 'high' ? 'bg-accent-soft' : (recommendation.priority == 'medium' ? 'bg-white/90' : 'bg-success-soft') }}">
                        <div class="flex flex-wrap items-center gap-2">
                            <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold {{ recommendation.priority == 'high' ? 'bg-white/90 text-emphasis' : (recommendation.priority == 'medium' ? 'border border-border bg-white/80 text-ink' : 'bg-white/90 text-success') }}">
                                {{ recommendation.badge }}
                            </span>
                            <p class="text-sm font-semibold text-ink">{{ recommendation.title }}</p>
                        </div>
                        <p class="mt-2 text-sm text-muted">{{ recommendation.message }}</p>
                        <ul class="mt-3 space-y-2 text-sm text-ink">
                            {% for action in recommendation.actions %}
                                <li class="flex items-start gap-2">
                                    <span class="mt-1 h-2 w-2 rounded-full bg-current opacity-70"></span>
                                    <span>{{ action }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    </article>
                {% endfor %}
            </div>
        </div>
    {% endif %}
</section>
