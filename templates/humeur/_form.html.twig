{{ form_start(form, { attr: { class: 'crud-form', novalidate: 'novalidate' } }) }}
    {% if not form.vars.valid %}
        <div class="form-error-summary">
            <div>!</div>
            <div>
                <strong>Submission failed</strong>
                <div>Please correct the highlighted fields before continuing.</div>
            </div>
        </div>
    {% endif %}

    <div class="field-grid">
        <div class="form-row{{ form.date.vars.valid ? '' : ' has-error' }}">
            {{ form_label(form.date) }}
            {{ form_widget(form.date) }}
            <div class="form-field-errors">{{ form_errors(form.date) }}</div>
        </div>

        <div class="form-row{{ form.typeHumeur.vars.valid ? '' : ' has-error' }}">
            {{ form_label(form.typeHumeur) }}
            {{ form_widget(form.typeHumeur) }}
            <div class="form-field-errors">{{ form_errors(form.typeHumeur) }}</div>
        </div>

        <div class="form-row{{ form.intensite.vars.valid ? '' : ' has-error' }}">
            {{ form_label(form.intensite) }}
            {{ form_widget(form.intensite) }}
            <div class="form-help">{{ form_help(form.intensite) }}</div>
            <div class="form-field-errors">{{ form_errors(form.intensite) }}</div>
        </div>
    </div>
    <button class="button-primary" type="submit">{{ button_label }}</button>
{{ form_end(form) }}
