{{ form_start(form, { attr: { class: 'crud-form', novalidate: 'novalidate' } }) }}
    {% if not form.vars.valid %}
        <div class="form-error-summary">
            <div>!</div>
            <div>
                <strong>Submission failed</strong>
                <div>Please fix the errors below before saving your journal.</div>
            </div>
        </div>
    {% endif %}

    <div class="field-grid">
        <div class="form-row{{ form.notePersonnelle.vars.valid ? '' : ' has-error' }}">
            {{ form_label(form.notePersonnelle) }}
            {{ form_widget(form.notePersonnelle) }}
            <div class="form-help">{{ form_help(form.notePersonnelle) }}</div>
            <div class="form-field-errors">{{ form_errors(form.notePersonnelle) }}</div>
        </div>

        <div class="form-row{{ form.dateCreation.vars.valid ? '' : ' has-error' }}">
            {{ form_label(form.dateCreation) }}
            {{ form_widget(form.dateCreation) }}
            <div class="form-field-errors">{{ form_errors(form.dateCreation) }}</div>
        </div>
    </div>
    <button class="button-primary" type="submit">{{ button_label }}</button>
{{ form_end(form) }}
