{% extends 'base.html.twig' %}

{% block title %}Set new password{% endblock %}

{% block body %}
    <main class="page-shell">
        <div class="app-shell max-w-xl">
            <section class="page-card">
                <div class="page-stack">
                    {{ component('PageHeader', {
                        eyebrow: 'Recovery',
                        title: 'Create a new password',
                        copy: 'Choose a new password for ' ~ email ~ '.'
                    }) }}

                    {{ component('FlashStack') }}

                    <form method="post" class="form-stack" novalidate>
                        <div class="field">
                            <label class="field-label" for="password">New password</label>
                            <input class="field-input {{ fieldErrors.password is defined ? 'field-input-invalid' : '' }}" type="password" id="password" name="password" autocomplete="new-password" required autofocus>
                            {% if fieldErrors.password is defined %}
                                <p class="field-error">{{ fieldErrors.password }}</p>
                            {% endif %}
                        </div>

                        <div class="field">
                            <label class="field-label" for="password_confirmation">Confirm password</label>
                            <input class="field-input {{ fieldErrors.password_confirmation is defined ? 'field-input-invalid' : '' }}" type="password" id="password_confirmation" name="password_confirmation" autocomplete="new-password" required>
                            {% if fieldErrors.password_confirmation is defined %}
                                <p class="field-error">{{ fieldErrors.password_confirmation }}</p>
                            {% endif %}
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('forgot_password_reset') }}">

                        <div class="button-row">
                            <button class="btn-primary" type="submit">Reset password</button>
                            <a class="btn-secondary" href="{{ path('app_login') }}">Back to sign in</a>
                        </div>
                    </form>
                </div>
            </section>
        </div>
    </main>
{% endblock %}
