{% extends 'base.html.twig' %}

{% block title %}Sign up{% endblock %}

{% block body %}
    <main class="container" style="max-width: 560px; margin-top: 4rem;">
        <h1>Create your account</h1>
        <p>Fill the fields below, then sign in with your new credentials.</p>

        {% for message in app.flashes('error') %}
            <div style="padding: 0.9rem 1rem; border: 1px solid #f2b8b5; background: #fff1f0; color: #8a1f17; border-radius: 10px; margin-bottom: 1rem;">
                {{ message }}
            </div>
        {% endfor %}

        <form method="post" style="display: grid; gap: 1rem;">
            <div>
                <label for="nom" style="display: block; margin-bottom: 0.35rem; font-weight: 600;">Last name</label>
                <input type="text" id="nom" name="nom" value="{{ form.nom|default('') }}" required style="width: 100%; padding: 0.8rem 0.9rem; border: 1px solid #d7dde5; border-radius: 10px;">
            </div>

            <div>
                <label for="prenom" style="display: block; margin-bottom: 0.35rem; font-weight: 600;">First name</label>
                <input type="text" id="prenom" name="prenom" value="{{ form.prenom|default('') }}" required style="width: 100%; padding: 0.8rem 0.9rem; border: 1px solid #d7dde5; border-radius: 10px;">
            </div>

            <div>
                <label for="email" style="display: block; margin-bottom: 0.35rem; font-weight: 600;">Email</label>
                <input type="email" id="email" name="email" value="{{ form.email|default('') }}" required style="width: 100%; padding: 0.8rem 0.9rem; border: 1px solid #d7dde5; border-radius: 10px;">
            </div>

            <div>
                <label for="age" style="display: block; margin-bottom: 0.35rem; font-weight: 600;">Age</label>
                <input type="number" id="age" name="age" min="10" max="120" value="{{ form.age|default('') }}" required style="width: 100%; padding: 0.8rem 0.9rem; border: 1px solid #d7dde5; border-radius: 10px;">
            </div>

            <div>
                <label for="password" style="display: block; margin-bottom: 0.35rem; font-weight: 600;">Password</label>
                <input type="password" id="password" name="password" minlength="6" required style="width: 100%; padding: 0.8rem 0.9rem; border: 1px solid #d7dde5; border-radius: 10px;">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('register') }}">

            <button type="submit" style="padding: 0.85rem 1.1rem; border: 0; border-radius: 10px; background: #1f6f78; color: #fff; font-weight: 700; cursor: pointer;">
                Create account
            </button>
        </form>

        <p style="margin-top: 1rem; color: var(--muted);">
            Already have an account?
            <a href="{{ path('app_login') }}" style="color: var(--brand); font-weight: 600;">Sign in</a>
        </p>
    </main>
{% endblock %}
