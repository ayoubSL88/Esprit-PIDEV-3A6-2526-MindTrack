{% extends 'base.html.twig' %}

{% block title %}Verify reset code{% endblock %}

{% block body %}
    <main class="page-shell">
        <div class="app-shell max-w-xl">
            <section class="page-card">
                <div class="page-stack">
                    {{ component('PageHeader', {
                        eyebrow: 'Recovery',
                        title: 'Verify reset code',
                        copy: 'Enter the 6-digit code sent to ' ~ form.email ~ '.'
                    }) }}

                    {{ component('FlashStack') }}

                    <form method="post" class="form-stack" novalidate>
                        <div class="field">
                            <label class="field-label" for="code">Reset code</label>
                            <input class="field-input {{ fieldErrors.code is defined ? 'field-input-invalid' : '' }}" type="text" id="code" name="code" value="{{ form.code|default('') }}" inputmode="numeric" maxlength="6" placeholder="000000" required autofocus>
                            {% if fieldErrors.code is defined %}
                                <p class="field-error">{{ fieldErrors.code }}</p>
                            {% endif %}
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('forgot_password_verify') }}">

                        <div class="button-row">
                            <button class="btn-primary" type="submit">Verify code</button>
                            <a class="btn-secondary" href="{{ path('app_forgot_password') }}">Start over</a>
                        </div>
                    </form>
                </div>
            </section>
        </div>
    </main>
{% endblock %}
